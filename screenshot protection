<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Screenshot Protection Demo</title>
<style>
  :root {
    --bg: #0f1115;
    --card: #171a21;
    --accent: #6ee7b7;
    --danger: #f87171;
    --text: #e5e7eb;
    --muted: #9ca3af;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    /* text/image selection & drag disable */
    user-select: none;
    -webkit-user-select: none;
  }
  .card {
    max-width: 640px;
    width: 100%;
    background: var(--card);
    border-radius: 16px;
    padding: 32px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.4);
  }
  h1 { font-size: 22px; margin: 0 0 4px; }
  .sub { color: var(--muted); font-size: 14px; margin-bottom: 24px; }
  .secret {
    background: #0d1f17;
    border: 1px solid var(--accent);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.5px;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 20px;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
  }
  .note {
    font-size: 13px;
    line-height: 1.6;
    color: var(--muted);
    background: #1e2129;
    border-left: 3px solid var(--danger);
    padding: 12px 14px;
    border-radius: 6px;
  }
  .note b { color: var(--text); }

  /* Full-screen blank overlay */
  #shield {
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 999999;
    display: none;
    align-items: center;
    justify-content: center;
  }
  #shield.active { display: flex; }
  #shield span {
    color: #333;
    font-size: 13px;
  }

  /* Blur content while overlay logic decides (window blur / devtools) */
  body.protected .card {
    filter: blur(0px);
    transition: filter 0.05s;
  }
  body.hide-content .card {
    filter: blur(30px) brightness(0.3);
  }
</style>
</head>
<body class="protected">

  <div class="card">
    <h1>🔒 Confidential Demo Content</h1>
    <div class="sub">Ye page screenshot-deterrent techniques demonstrate karta hai</div>

    <div class="secret">
      SECRET CODE: X7K-992-QP
    </div>

    <div class="status">
      <span class="dot"></span>
      <span id="statusText">Protection active</span>
    </div>

    <div class="note">
      <b>Important:</b> Ye sirf deterrent hai, guarantee nahi. Browser/JS ke paas OS-level
      screenshot tools (Snipping Tool, phone screenshot, external camera) ko block karne ki
      capability nahi hai. Koi bhi website ye 100% nahi rok sakti.
    </div>
  </div>

  <div id="shield"><span>Protected content</span></div>

  <script>
    const shield = document.getElementById('shield');
    const statusText = document.getElementById('statusText');
    let hideTimeout;

    function showShield(reason, duration = 1200) {
      shield.classList.add('active');
      document.body.classList.add('hide-content');
      statusText.textContent = 'Blocked: ' + reason;
      clearTimeout(hideTimeout);
      hideTimeout = setTimeout(() => {
        shield.classList.remove('active');
        document.body.classList.remove('hide-content');
        statusText.textContent = 'Protection active';
      }, duration);
    }

    // 1) PrintScreen key detect — any combination (with/without Ctrl/Alt/Shift held)
    //    Note: PrintScreen fires only on 'keyup' in most browsers, never 'keydown'.
    //    Win+PrintScreen / Fn+Win+PrintScreen are intercepted by the OS before
    //    they ever reach the browser, so they CANNOT be caught here — this only
    //    works for plain PrintScreen (with optional Ctrl/Alt/Shift).
    async function blankClipboardImage() {
      try {
        const canvas = document.createElement('canvas');
        canvas.width = 1;
        canvas.height = 1;
        const blob = await new Promise(res => canvas.toBlob(res, 'image/png'));
        if (blob && navigator.clipboard && window.ClipboardItem) {
          await navigator.clipboard.write([
            new ClipboardItem({ 'image/png': blob })
          ]);
        }
      } catch (err) {
        // Silently ignore — clipboard overwrite isn't guaranteed to work.
      }
    }

    window.addEventListener('keyup', (e) => {
      if (e.key === 'PrintScreen') {
        showShield('PrintScreen key detected', 2500);
        blankClipboardImage();
      }
    });

    // 2) Common screenshot/devtools shortcuts (Win+Shift+S triggers blur, Cmd+Shift+3/4 on Mac too)
    window.addEventListener('keydown', (e) => {
      const key = e.key.toLowerCase();
      const isDevTools =
        e.key === 'F12' ||
        (e.ctrlKey && e.shiftKey && ['i','j','c'].includes(key)) ||
        (e.metaKey && e.altKey && ['i','j','c'].includes(key));
      if (isDevTools) {
        e.preventDefault();
        showShield('DevTools shortcut blocked');
      }
    });

    // 3) Window loses focus (screenshot tool overlay, alt-tab, snipping tool opening)
    window.addEventListener('blur', () => {
      document.body.classList.add('hide-content');
      statusText.textContent = 'Window not focused — content hidden';
    });
    window.addEventListener('focus', () => {
      document.body.classList.remove('hide-content');
      statusText.textContent = 'Protection active';
    });

    // 4) Tab/visibility change
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        document.body.classList.add('hide-content');
      } else {
        document.body.classList.remove('hide-content');
      }
    });

    // 5) Disable right-click context menu
    window.addEventListener('contextmenu', (e) => e.preventDefault());

    // 6) Disable drag on content (prevents easy image drag-save)
    window.addEventListener('dragstart', (e) => e.preventDefault());

    // 7) Basic DevTools-open heuristic via window size delta
    let devtoolsOpen = false;
    setInterval(() => {
      const threshold = 160;
      const widthDiff = window.outerWidth - window.innerWidth;
      const heightDiff = window.outerHeight - window.innerHeight;
      const isOpen = widthDiff > threshold || heightDiff > threshold;
      if (isOpen && !devtoolsOpen) {
        devtoolsOpen = true;
        showShield('DevTools panel detected', 999999999);
      } else if (!isOpen && devtoolsOpen) {
        devtoolsOpen = false;
        shield.classList.remove('active');
        document.body.classList.remove('hide-content');
        statusText.textContent = 'Protection active';
      }
    }, 500);
  </script>

</body>
</html>