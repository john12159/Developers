<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>PrintScreen Demo</title>
<style>
body{
    margin:0;
    font-family:Arial,sans-serif;
}

#overlay{
    position:fixed;
    inset:0;
    background:black;
    display:none;
    z-index:99999;
}

.content{
    padding:40px;
}
</style>
</head>
<body>

<div id="overlay"></div>

<div class="content">
    <h1>Sensitive Demo</h1>
    <p>Try pressing PrintScreen.</p>
</div>

<script>
const overlay = document.getElementById("overlay");

function hideScreen() {
    overlay.style.display = "block";

    setTimeout(() => {
        overlay.style.display = "none";
    }, 500);
}

document.addEventListener("keydown", e => {
    if (e.key === "PrintScreen") {
        hideScreen();
    }
});
</script>

</body>
</html>