<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Verification Demo</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,Helvetica,sans-serif;
}

body{
    background:#f5f5f5;
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.card{
    width:400px;
    background:#fff;
    padding:35px;
    border-radius:15px;
    box-shadow:0 8px 25px rgba(0,0,0,.15);
}

.logo{
    width:55px;
    height:55px;
    border-radius:50%;
    background:#4285f4;
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:28px;
    font-weight:bold;
}

h1{
    margin-top:20px;
    font-size:34px;
    font-weight:500;
}

p{
    color:#666;
    margin-top:15px;
    line-height:1.6;
}

.email{
    margin-top:20px;
    border:1px solid #ccc;
    border-radius:30px;
    padding:12px 18px;
}

.number{
    font-size:90px;
    text-align:center;
    margin:40px 0;
    font-weight:300;
}

button{
    width:100%;
    padding:14px;
    border:none;
    background:#1a73e8;
    color:white;
    border-radius:8px;
    cursor:pointer;
    font-size:16px;
}

button:hover{
    background:#1558c0;
}
</style>
</head>

<body>

<div class="card">

<div class="logo">V</div>

<h1>Verify Your Identity</h1>

<p>
For your security, please confirm that this sign-in request belongs to you.
</p>

<div class="email">
📧 john@example.com
</div>

<div class="number" id="code">10</div>

<p>
Open your trusted device and enter the number shown above to continue.
</p>

<br>

<button onclick="generate()">Generate New Number</button>

</div>

<script>
function generate(){
    document.getElementById("code").innerText =
    Math.floor(Math.random()*90)+10;
}
</script>

</body>
</html>