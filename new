<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Two-Factor Authentication | Tasbih Account</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-deep: #0D3B2E;
    --bg-deep-2: #0A2E23;
    --gold: #C9A35C;
    --gold-soft: #E3CB94;
    --card: #FAF6EE;
    --ink: #1A2620;
    --muted: #5C6B63;
    --line: #E2D9C4;
  }

  *{ box-sizing: border-box; }

  html, body{ height:100%; }

  body{
    margin:0;
    min-height:100vh;
    font-family:'Inter', sans-serif;
    background:
      radial-gradient(circle at 20% 15%, rgba(201,163,92,0.10), transparent 40%),
      radial-gradient(circle at 80% 85%, rgba(201,163,92,0.08), transparent 45%),
      linear-gradient(160deg, var(--bg-deep) 0%, var(--bg-deep-2) 100%);
    position:relative;
    overflow:hidden;
  }

  /* subtle geometric pattern overlay, faint */
  body::before{
    content:"";
    position:absolute;
    inset:0;
    background-image:
      repeating-linear-gradient(45deg, rgba(201,163,92,0.035) 0px, rgba(201,163,92,0.035) 1px, transparent 1px, transparent 26px),
      repeating-linear-gradient(-45deg, rgba(201,163,92,0.035) 0px, rgba(201,163,92,0.035) 1px, transparent 1px, transparent 26px);
    pointer-events:none;
  }

  .page{
    position:relative;
    z-index:1;
    min-height:100vh;
    display:flex;
    flex-direction:column;
  }

  .center-wrap{
    flex:1;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:32px 16px;
  }

  .card{
    position:relative;
    z-index:1;
    width:100%;
    max-width:420px;
    background:var(--card);
    border-radius:22px;
    padding:44px 36px 32px;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.4) inset,
      0 30px 60px -20px rgba(0,0,0,0.45);
    border:1px solid rgba(201,163,92,0.25);
  }

  .tasbih-icon{
    width:84px;
    height:84px;
    margin:0 auto 22px;
    display:block;
  }

  h1{
    font-family:'Amiri', serif;
    font-size:27px;
    line-height:1.3;
    color:var(--ink);
    text-align:center;
    margin:0 0 18px;
    font-weight:700;
  }

  .otp-intro{
    text-align:center;
    font-size:13.5px;
    line-height:1.6;
    color:var(--muted);
    margin:0 0 26px;
  }

  .otp-boxes{
    display:flex;
    justify-content:center;
    gap:9px;
    margin-bottom:22px;
  }
  .otp-boxes input{
    width:42px;
    height:52px;
    text-align:center;
    font-size:20px;
    font-weight:600;
    font-family:'Inter', sans-serif;
    color:var(--ink);
    border:1.5px solid var(--line);
    border-radius:10px;
    background:#fff;
    outline:none;
    transition:border-color .15s ease, box-shadow .15s ease;
  }
  .otp-boxes input:focus{
    border-color:var(--gold);
    box-shadow:0 0 0 3px rgba(201,163,92,0.18);
  }
  .otp-boxes input.error{
    border-color:#B3493D;
    box-shadow:0 0 0 3px rgba(179,73,61,0.15);
  }

  .otp-error{
    text-align:center;
    font-size:12.5px;
    color:#B3493D;
    margin:0 0 16px;
    min-height:16px;
  }

  .otp-links{
    text-align:center;
    margin-bottom:24px;
  }
  .otp-links a{
    display:block;
    font-size:13.5px;
    color:#1E5C44;
    text-decoration:none;
    font-weight:600;
    margin-bottom:8px;
  }
  .otp-links a:hover{ text-decoration:underline; }
  .otp-links a.disabled{
    color:var(--muted);
    cursor:default;
    pointer-events:none;
  }

  .otp-help{
    text-align:center;
    font-size:11.5px;
    line-height:1.6;
    color:var(--muted);
    margin:18px 0 0;
  }
  .otp-help a{ color:#1E5C44; text-decoration:none; font-weight:600; }
  .otp-help a:hover{ text-decoration:underline; }

  @media (max-width: 600px){
    .center-wrap{ padding:28px 24px; align-items:flex-start; }
    .card{
      max-width:100%;
      width:100%;
      padding:0;
      background:transparent;
      border:none;
      border-radius:0;
      box-shadow:none;
    }
    .tasbih-icon{ width:96px; height:96px; }
  }

  @media (max-width: 380px){
    .otp-boxes{ gap:6px; }
    .otp-boxes input{ width:38px; height:48px; font-size:18px; }
  }

  .footer{
    text-align:center;
    padding:20px 16px 24px;
    font-size:11px;
    color:rgba(255,255,255,0.65);
  }
  .footer a{ color:rgba(255,255,255,0.78); text-decoration:none; margin:0 8px; }
  .footer a:hover{ text-decoration:underline; }
  .footer .copyright{ margin-top:8px; display:block; color:rgba(255,255,255,0.45); }
</style>
</head>
<body>

  <div class="page">
    <div class="center-wrap">
      <div class="card">
        <svg class="tasbih-icon" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="34" stroke="#C9A35C" stroke-width="1.4" stroke-dasharray="2 6"/>
          <g fill="#1E6B4F">
            <circle cx="50" cy="16" r="5.2"/>
            <circle cx="68" cy="21" r="5.2"/>
            <circle cx="80" cy="35" r="5.2"/>
            <circle cx="84" cy="50" r="5.2"/>
            <circle cx="80" cy="65" r="5.2"/>
            <circle cx="68" cy="79" r="5.2"/>
            <circle cx="50" cy="84" r="5.2"/>
            <circle cx="32" cy="79" r="5.2"/>
            <circle cx="20" cy="65" r="5.2"/>
            <circle cx="16" cy="50" r="5.2"/>
            <circle cx="20" cy="35" r="5.2"/>
            <circle cx="32" cy="21" r="5.2"/>
          </g>
          <circle cx="50" cy="50" r="9" fill="#C9A35C"/>
        </svg>

        <h1>Two-factor<br>authentication</h1>
        <p class="otp-intro" id="otpIntro">
          A message with a verification code has been sent to your device.
          Please enter the code to continue.
        </p>

        <div class="otp-boxes" id="otpBoxes">
          <input type="text" inputmode="numeric" maxlength="1" autocomplete="one-time-code">
          <input type="text" inputmode="numeric" maxlength="1">
          <input type="text" inputmode="numeric" maxlength="1">
          <input type="text" inputmode="numeric" maxlength="1">
          <input type="text" inputmode="numeric" maxlength="1">
          <input type="text" inputmode="numeric" maxlength="1">
        </div>

        <p class="otp-error" id="otpError"></p>

        <div class="otp-links">
          <a href="#" id="resendCode">Resend code</a>
          <a href="#">Cannot access your devices?</a>
        </div>

        <p class="otp-help">
          If you cannot enter a code because you have lost your device, you can use
          <a href="#">Find Device</a> to locate it or <a href="#">Manage Device</a>
          to remove your Tasbih Account from it.
        </p>
      </div>
    </div>

    <div class="footer">
      <a href="#">System Status</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms &amp; Conditions</a>
      <span class="copyright">Copyright © 2026 Tasbih Inc. All rights reserved.</span>
    </div>
  </div>

  <script>
    const otpInputs = Array.from(document.querySelectorAll('#otpBoxes input'));
    const resendCode = document.getElementById('resendCode');
    const otpError = document.getElementById('otpError');
    const otpIntro = document.getElementById('otpIntro');

    // Show which email the code was sent to, if passed via ?email=
    const params = new URLSearchParams(window.location.search);
    const email = params.get('email');
    if (email) {
      otpIntro.textContent = 'A message with a verification code has been sent to your device for ' + email + '. Please enter the code to continue.';
    }

    otpInputs[0].focus();

    function checkComplete() {
      if (otpInputs.every(i => i.value)) {
        const code = otpInputs.map(i => i.value).join('');
        // Hook up real verification here.
        console.log('OTP submitted:', code);
        otpError.textContent = '';
      }
    }

    otpInputs.forEach((input, idx) => {
      input.addEventListener('input', () => {
        input.value = input.value.replace(/[^0-9]/g, '').slice(0, 1);
        input.classList.remove('error');
        if (input.value && idx < otpInputs.length - 1) {
          otpInputs[idx + 1].focus();
        }
        checkComplete();
      });

      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !input.value && idx > 0) {
          otpInputs[idx - 1].focus();
        }
      });

      input.addEventListener('paste', (e) => {
        const pasted = (e.clipboardData || window.clipboardData).getData('text').replace(/[^0-9]/g, '');
        if (!pasted) return;
        e.preventDefault();
        pasted.split('').slice(0, otpInputs.length).forEach((digit, i) => {
          otpInputs[i].value = digit;
        });
        const next = Math.min(pasted.length, otpInputs.length - 1);
        otpInputs[next].focus();
        checkComplete();
      });
    });

    let resendCooldown = 0;
    function startResendCooldown() {
      resendCooldown = 30;
      resendCode.classList.add('disabled');
      const tick = () => {
        if (resendCooldown <= 0) {
          resendCode.classList.remove('disabled');
          resendCode.textContent = 'Resend code';
          return;
        }
        resendCode.textContent = 'Resend code (' + resendCooldown + 's)';
        resendCooldown -= 1;
        setTimeout(tick, 1000);
      };
      tick();
    }

    resendCode.addEventListener('click', (e) => {
      e.preventDefault();
      if (resendCode.classList.contains('disabled')) return;
      otpInputs.forEach(i => { i.value = ''; i.classList.remove('error'); });
      otpInputs[0].focus();
      otpError.textContent = '';
      console.log('Resend code requested for', email || 'unknown email');
      startResendCooldown();
    });
  </script>

</body>
</html>