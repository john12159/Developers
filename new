<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Google Verification</title>

<link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500&family=Roboto:wght@400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="style.css">
</head>
<body>

<div class="container">

    <img src="https://www.gstatic.com/images/branding/googlelogo/2x/googlelogo_color_92x30dp.png"
         class="logo">

    <h1>Verify that it's you</h1>

    <p class="subtitle">
        To help keep your account safe, Google wants to
        make sure that it's really you
    </p>

    <div class="account-box">

        <div class="avatar">J</div>

        <span>johnsmithwwep@gmail.com</span>

        <span class="arrow">&#9662;</span>

    </div>

    <div class="number">10</div>

    <h2>Check your Redmi Note 13 Pro+ 5G</h2>

    <p class="text">
        Google sent a notification to your Redmi Note 13 Pro+ 5G.
        Tap <b>Yes</b> on the Google prompt, then tap
        <b>10</b> on your phone to verify that it's you.
    </p>

    <p class="help">
        Need help?
        <a href="#">Learn more about Google prompts</a>
    </p>

    <a href="#" class="link">Resend it</a>

    <a href="#" class="link">More ways to verify</a>

</div>

<footer>

<div>English (United Kingdom) ¨‹</div>

<div class="footer-links">
<a href="#">Help</a>
<a href="#">Privacy</a>
<a href="#">Terms</a>
</div>

</footer>

<script src="script.js"></script>

</body>
</html>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{

font-family:Roboto,sans-serif;
background:#fff;
display:flex;
flex-direction:column;
align-items:center;
justify-content:flex-start;
min-height:100vh;
color:#202124;

}

.container{

width:100%;
max-width:430px;
padding:35px 26px;

}

.logo{

width:74px;
margin-bottom:28px;

}

h1{

font-family:'Google Sans',sans-serif;
font-size:50px;
font-weight:400;
line-height:1.2;
margin-bottom:18px;

}

.subtitle{

font-size:18px;
line-height:1.6;
color:#3c4043;
margin-bottom:25px;

}

.account-box{

height:54px;
border:1px solid #dadce0;
border-radius:28px;
display:flex;
align-items:center;
padding:0 16px;
gap:12px;
width:100%;
margin-bottom:50px;

}

.avatar{

width:32px;
height:32px;
border-radius:50%;
background:#9e8d84;
display:flex;
justify-content:center;
align-items:center;
color:#fff;
font-weight:500;
font-size:18px;

}

.account-box span{

font-size:21px;

}

.arrow{

margin-left:auto;
font-size:16px;

}

.number{

font-size:120px;
font-weight:300;
text-align:center;
line-height:1;
margin-bottom:30px;

}

h2{

font-family:'Google Sans';
font-size:35px;
font-weight:400;
margin-bottom:18px;

}

.text{

font-size:18px;
line-height:1.6;
color:#3c4043;

}

.help{

margin-top:22px;
font-size:18px;

}

.help a{

text-decoration:none;
color:#1a73e8;

}

.link{

display:block;
margin-top:55px;
text-decoration:none;
font-size:22px;
color:#1a73e8;

}

footer{

width:100%;
max-width:430px;
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 26px 28px;
font-size:15px;
color:#5f6368;

}

.footer-links{

display:flex;
gap:22px;

}

.footer-links a{

text-decoration:none;
color:#5f6368;

}

@media(max-width:450px){

.container{

padding:28px 20px;

}

h1{

font-size:38px;

}

h2{

font-size:28px;

}

.number{

font-size:100px;

}

.account-box span{

font-size:18px;

}

.subtitle,
.text{

font-size:16px;

}

}
document.querySelector(".account-box").addEventListener("click", () => {
    alert("Account switcher clicked");
});

document.querySelector(".link").addEventListener("click", e => {
    e.preventDefault();
});