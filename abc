<script>
// ===================== CURSOR =====================
const cursor = document.getElementById('cursor');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX + 'px';
  cursor.style.top  = e.clientY + 'px';
  spawnMouseParticle(e.clientX, e.clientY);
});

function spawnMouseParticle(x, y) {
  if (Math.random() > 0.3) return;
  const p = document.createElement('div');
  const size = 4 + Math.random() * 6;
  const colors = ['#fbbf24','#f97316','#ec4899','#a78bfa','#34d399','#60a5fa'];
  p.style.cssText = `position:fixed;width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:50%;left:${x}px;top:${y}px;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);`;
  document.body.appendChild(p);
  let vy = -2 - Math.random()*3, vx = (Math.random()-0.5)*4, opacity = 1;
  const animate = () => {
    vy += 0.1; vx *= 0.98;
    const cx = parseFloat(p.style.left) + vx;
    const cy = parseFloat(p.style.top) + vy;
    opacity -= 0.03;
    p.style.left = cx+'px'; p.style.top = cy+'px'; p.style.opacity = opacity;
    if (opacity > 0) requestAnimationFrame(animate); else p.remove();
  };
  requestAnimationFrame(animate);
}

// ===================== STARS =====================
const starsEl = document.getElementById('stars');
for (let i = 0; i < 80; i++) {
  const s = document.createElement('div');
