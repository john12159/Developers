<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Apple Sign In Clone</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    body{
      background:#f5f5f7;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:100vh;
    }

    .container{
      width:100%;
      max-width:420px;
      background:#fff;
      padding:40px;
      border-radius:18px;
      box-shadow:0 10px 30px rgba(0,0,0,0.08);
      text-align:center;
    }

    .apple-logo{
      width:70px;
      height:70px;
      margin:0 auto 20px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      background: conic-gradient(
        #ff3b30,
        #ff9500,
        #ffcc00,
        #34c759,
        #5ac8fa,
        #007aff,
        #af52de,
        #ff2d55,
        #ff3b30
      );
      padding:4px;
    }

    .apple-logo span{
      width:100%;
      height:100%;
      border-radius:50%;
      background:#fff;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:34px;
    }

    h1{
      font-size:30px;
      font-weight:600;
      margin-bottom:30px;
      color:#1d1d1f;
    }

    .input-group{
      margin-bottom:20px;
    }

    input{
      width:100%;
      padding:16px;
      border:1px solid #d2d2d7;
      border-radius:12px;
      font-size:16px;
      transition:0.3s;
      outline:none;
    }

    input:focus{
      border-color:#0071e3;
      box-shadow:0 0 0 4px rgba(0,113,227,0.15);
    }

    .create-account{
      display:block;
      text-align:left;
      margin-top:10px;
      font-size:14px;
      color:#0071e3;
      text-decoration:none;
    }

    .info{
      text-align:left;
      font-size:12px;
      color:#6e6e73;
      line-height:1.5;
      margin:20px 0;
    }

    .btn-group{
      display:flex;
      gap:10px;
      margin-top:20px;
    }

    button{
      flex:1;
      padding:14px;
      border:none;
      border-radius:10px;
      cursor:pointer;
      font-size:15px;
      font-weight:500;
      transition:0.3s;
    }

    .continue-btn{
      background:#0071e3;
      color:white;
    }

    .continue-btn:hover{
      background:#005fc2;
    }

    .iphone-btn{
      background:#1d1d1f;
      color:white;
    }

    .iphone-btn:hover{
      background:#000;
    }

    .message{
      margin-top:18px;
      font-size:14px;
      color:green;
    }

    .error{
      color:red;
    }

    @media(max-width:500px){
      .container{
        margin:20px;
        padding:30px 25px;
      }

      .btn-group{
        flex-direction:column;
      }
    }
  </style>
</head>

<body>

  <div class="container">

    <div class="apple-logo">
      <span></span>
    </div>

    <h1>Sign in with Apple Account</h1>

    <div class="input-group">
      <input 
        type="text" 
        id="email"
        placeholder="Email or Phone Number"
      >

      <a href="#" class="create-account">
        Create Your Apple Account
      </a>
    </div>

    <div class="info">
      Your Apple Account information is used to allow you to sign in securely
      and access your data. Apple records certain data for security, support,
      and reporting purposes.
    </div>

    <div class="btn-group">
      <button class="continue-btn" onclick="login()">
        Continue
      </button>

      <button class="iphone-btn" onclick="iphoneLogin()">
         Sign in with iPhone
      </button>
    </div>

    <div class="message" id="message"></div>

  </div>

  <script>

    function login(){

      let email = document.getElementById("email").value;
      let message = document.getElementById("message");

      if(email === ""){
        message.innerHTML = "Please enter Email or Phone Number";
        message.classList.add("error");
        return;
      }

      // Email validation
      let emailPattern = /^[^ ]+@[^ ]+\.[a-z]{2,3}$/;

      // Phone validation
      let phonePattern = /^[0-9]{10}$/;

      if(email.match(emailPattern) || email.match(phonePattern)){
        message.classList.remove("error");
        message.innerHTML = "Login Successful!";
      }else{
        message.classList.add("error");
        message.innerHTML = "Invalid Email or Phone Number";
      }
    }

    function iphoneLogin(){
      alert("Redirecting to iPhone Sign In...");
    }

  </script>

</body>
</html>