<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Skylark — Weather, anywhere</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    /* token system — shifts per weather state via data-sky on <body> */
    --ink:#1b1f23;
    --paper:#eef1f4;
    --card:#ffffffcc;
    --line: rgba(27,31,35,0.12);
    --accent:#2f6fed;
    --accent-soft: rgba(47,111,237,0.14);
    --mono: 'JetBrains Mono', monospace;
    --display: 'Fraunces', serif;
    --body: 'Space Grotesk', sans-serif;

    --sky-top:#aebfd6;
    --sky-bot:#eef1f4;
    --sun:#ffd76a;
  }

  /* ---- weather-driven palettes ---- */
  body[data-sky="clear-day"]{
    --sky-top:#4f8ef0; --sky-bot:#bfe1ff; --ink:#102032; --accent:#e8862f; --accent-soft:rgba(232,134,47,.16);
  }
  body[data-sky="clear-night"]{
    --sky-top:#0b1330; --sky-bot:#2a3a6b; --ink:#eef1f8; --paper:#0e1530; --card:rgba(20,28,56,0.72); --line:rgba(255,255,255,0.14); --accent:#8fb4ff; --accent-soft:rgba(143,180,255,.18);
  }
  body[data-sky="cloudy"]{
    --sky-top:#7c8a99; --sky-bot:#d4dbe1; --ink:#1c2228; --accent:#3f6b8f; --accent-soft:rgba(63,107,143,.15);
  }
  body[data-sky="rain"]{
    --sky-top:#37475a; --sky-bot:#7c93a8; --ink:#101820; --paper:#dfe6ea; --accent:#1f5fa8; --accent-soft:rgba(31,95,168,.16);
  }
  body[data-sky="storm"]{
    --sky-top:#222633; --sky-bot:#4a4f63; --ink:#f1f2f6; --paper:#15161e; --card:rgba(28,29,38,0.78); --line:rgba(255,255,255,0.14); --accent:#f0c93a; --accent-soft:rgba(240,201,58,.18);
  }
  body[data-sky="snow"]{
    --sky-top:#aebfd9; --sky-bot:#f3f6fa; --ink:#1a2330; --accent:#3a6fa8; --accent-soft:rgba(58,111,168,.14);
  }
  body[data-sky="fog"]{
    --sky-top:#b9bcc1; --sky-bot:#e7e7e6; --ink:#23262a; --accent:#5b5f66; --accent-soft:rgba(91,95,102,.14);
  }

  *{margin:0;padding:0;box-sizing:border-box;}
  html,body{min-height:100%;}
  body{
    font-family:var(--body);
    color:var(--ink);
    background: linear-gradient(180deg,var(--sky-top) 0%, var(--sky-bot) 62%, var(--paper) 100%);
    background-attachment:fixed;
    min-height:100vh;
    transition: background 900ms ease, color 500ms ease;
    overflow-x:hidden;
  }

  /* ambient sky canvas */
  #sky-fx{position:fixed; inset:0; pointer-events:none; z-index:0; overflow:hidden;}

  .wrap{
    position:relative; z-index:1;
    max-width:920px; margin:0 auto; padding:40px 24px 80px;
  }

  /* ---- header / search ---- */
  header{
    display:flex; align-items:flex-start; justify-content:space-between; gap:20px;
    margin-bottom:38px; flex-wrap:wrap;
  }
  .brand{display:flex; align-items:center; gap:10px;}
  .brand-mark{
    width:34px;height:34px;border-radius:50%;
    background: radial-gradient(circle at 32% 30%, var(--sun), transparent 60%), var(--accent);
    flex-shrink:0;
  }
  .brand-name{
    font-family:var(--display); font-weight:600; font-size:1.35rem; letter-spacing:-0.01em;
  }
  .brand-sub{
    font-family:var(--mono); font-size:0.68rem; letter-spacing:0.08em; text-transform:uppercase; opacity:0.55; margin-top:2px;
  }

  .search-shell{
    position:relative; width:100%; max-width:380px;
  }
  .search-box{
    display:flex; align-items:center; gap:10px;
    background:var(--card); backdrop-filter:blur(14px);
    border:1px solid var(--line); border-radius:999px;
    padding:12px 18px;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .search-box:focus-within{
    border-color:var(--accent);
    box-shadow:0 0 0 4px var(--accent-soft);
  }
  .search-box svg{flex-shrink:0; opacity:0.55;}
  .search-box input{
    border:none; background:none; outline:none; width:100%;
    font-family:var(--body); font-size:0.95rem; color:var(--ink);
  }
  .search-box input::placeholder{color:var(--ink); opacity:0.42;}
  .locate-btn{
    border:none; background:none; cursor:pointer; opacity:0.55; flex-shrink:0;
    display:flex; align-items:center; padding:2px; border-radius:50%;
    transition: opacity 150ms, background 150ms;
  }
  .locate-btn:hover{opacity:1; background:var(--accent-soft);}

  .suggest{
    position:absolute; top:calc(100% + 8px); left:0; right:0;
    background:var(--card); backdrop-filter:blur(14px);
    border:1px solid var(--line); border-radius:16px;
    overflow:hidden; z-index:5;
    box-shadow:0 12px 32px rgba(0,0,0,0.12);
    display:none;
  }
  .suggest.show{display:block;}
  .suggest button{
    display:block; width:100%; text-align:left; border:none; background:none; cursor:pointer;
    padding:11px 18px; font-family:var(--body); font-size:0.88rem; color:var(--ink);
    border-bottom:1px solid var(--line);
  }
  .suggest button:last-child{border-bottom:none;}
  .suggest button:hover{background:var(--accent-soft);}
  .suggest .muted{opacity:0.55; font-size:0.78rem; margin-left:6px;}

  /* ---- hero ---- */
  .hero{
    display:grid; grid-template-columns:1.2fr 1fr; gap:32px; align-items:end;
    margin-bottom:44px; min-height:200px;
  }
  .hero-place{
    font-family:var(--mono); font-size:0.78rem; letter-spacing:0.06em; text-transform:uppercase; opacity:0.6;
    margin-bottom:6px; display:flex; align-items:center; gap:8px;
  }
  .hero-place .dot{width:6px;height:6px;border-radius:50%;background:var(--accent);}
  .hero-city{
    font-family:var(--display); font-weight:600; font-size:clamp(2.1rem, 5vw, 3.4rem);
    letter-spacing:-0.02em; line-height:1.02; margin-bottom:14px;
  }
  .hero-desc{font-size:1.05rem; opacity:0.78; max-width:34ch;}
  .hero-right{text-align:right;}
  .hero-temp{
    font-family:var(--display); font-weight:500; font-size:clamp(4rem, 11vw, 6.4rem);
    line-height:0.9; letter-spacing:-0.03em;
  }
  .hero-temp sup{font-size:0.4em; font-weight:400; opacity:0.7; top:-0.5em;}
  .hero-feels{font-family:var(--mono); font-size:0.78rem; opacity:0.6; margin-top:6px;}
  .hero-icon{width:84px; height:84px; margin-left:auto; margin-bottom:8px;}

  /* ---- stat strip ---- */
  .stats{
    display:grid; grid-template-columns:repeat(4,1fr); gap:1px;
    background:var(--line); border:1px solid var(--line); border-radius:18px;
    overflow:hidden; margin-bottom:36px;
  }
  .stat{
    background:var(--card); backdrop-filter:blur(14px);
    padding:18px 16px;
  }
  .stat-label{font-family:var(--mono); font-size:0.66rem; letter-spacing:0.06em; text-transform:uppercase; opacity:0.55; margin-bottom:6px;}
  .stat-value{font-family:var(--display); font-weight:600; font-size:1.4rem;}
  .stat-value span{font-size:0.6em; opacity:0.6; font-family:var(--body); font-weight:400;}

  /* ---- section heads ---- */
  .section-head{
    display:flex; align-items:baseline; justify-content:space-between; margin-bottom:14px;
  }
  .section-title{
    font-family:var(--display); font-weight:600; font-size:1.15rem;
  }
  .section-note{font-family:var(--mono); font-size:0.7rem; opacity:0.5; text-transform:uppercase; letter-spacing:0.05em;}

  /* ---- hourly rail ---- */
  .hourly-rail{
    display:flex; gap:10px; overflow-x:auto; padding-bottom:10px; margin-bottom:40px;
    scrollbar-width:thin;
  }
  .hour-card{
    flex:0 0 auto; width:78px; text-align:center;
    background:var(--card); backdrop-filter:blur(14px);
    border:1px solid var(--line); border-radius:16px; padding:14px 8px;
  }
  .hour-card .t{font-family:var(--mono); font-size:0.68rem; opacity:0.55; margin-bottom:8px;}
  .hour-card svg{width:30px; height:30px; margin:0 auto 8px;}
  .hour-card .v{font-family:var(--display); font-weight:600; font-size:1.05rem;}

  /* ---- daily list ---- */
  .daily-list{
    display:flex; flex-direction:column; gap:1px;
    background:var(--line); border:1px solid var(--line); border-radius:18px; overflow:hidden;
    margin-bottom:40px;
  }
  .day-row{
    display:grid; grid-template-columns:100px 32px 1fr auto auto; align-items:center; gap:16px;
    background:var(--card); backdrop-filter:blur(14px);
    padding:14px 18px;
  }
  .day-name{font-family:var(--body); font-weight:600; font-size:0.88rem;}
  .day-name .sub{display:block; font-family:var(--mono); font-weight:400; font-size:0.66rem; opacity:0.5; text-transform:uppercase; margin-top:1px;}
  .day-row svg{width:26px;height:26px;}
  .day-bar-track{
    height:5px; border-radius:4px; background:var(--line); position:relative; overflow:hidden;
  }
  .day-bar-fill{
    position:absolute; height:100%; border-radius:4px;
    background:linear-gradient(90deg, var(--accent-soft), var(--accent));
  }
  .day-lo{font-family:var(--mono); font-size:0.85rem; opacity:0.5; justify-self:end;}
  .day-hi{font-family:var(--mono); font-size:0.85rem; font-weight:500; justify-self:end;}

  /* ---- footer meta ---- */
  .meta-strip{
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:8px;
    font-family:var(--mono); font-size:0.68rem; opacity:0.45; letter-spacing:0.03em;
    border-top:1px solid var(--line); padding-top:18px;
  }

  /* ---- states ---- */
  .state-box{
    text-align:center; padding:60px 20px; opacity:0.7;
  }
  .state-box .spinner{
    width:34px;height:34px;border-radius:50%;
    border:3px solid var(--line); border-top-color:var(--accent);
    margin:0 auto 16px; animation:spin 0.8s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg);}}
  .state-box p{font-family:var(--mono); font-size:0.82rem;}
  .error-box{
    background:var(--card); border:1px solid var(--line); border-radius:16px;
    padding:24px; text-align:center; margin-bottom:30px; display:none;
  }
  .error-box.show{display:block;}
  .error-box p{font-family:var(--body); font-size:0.92rem; opacity:0.8;}

  .content{display:none;}
  .content.show{display:block; animation:fadeUp 500ms ease both;}
  @keyframes fadeUp{from{opacity:0; transform:translateY(10px);} to{opacity:1; transform:translateY(0);}}

  /* ---- units toggle ---- */
  .units-toggle{
    display:flex; gap:0; border:1px solid var(--line); border-radius:999px; overflow:hidden;
    font-family:var(--mono); font-size:0.72rem; flex-shrink:0;
  }
  .units-toggle button{
    border:none; background:var(--card); backdrop-filter:blur(14px); cursor:pointer;
    padding:10px 16px; color:var(--ink); opacity:0.55;
  }
  .units-toggle button.active{background:var(--accent); color:#fff; opacity:1;}

  .controls-row{display:flex; gap:14px; align-items:flex-start; flex-wrap:wrap;}

  @media (max-width:640px){
    .hero{grid-template-columns:1fr; text-align:left;}
    .hero-right{text-align:left;}
    .hero-icon{margin-left:0;}
    .stats{grid-template-columns:repeat(2,1fr);}
    .day-row{grid-template-columns:78px 26px 1fr auto auto; padding:12px 14px; gap:10px;}
  }

  @media (prefers-reduced-motion: reduce){
    *{animation-duration:0.01ms !important; transition-duration:0.01ms !important;}
  }
</style>
</head>
<body data-sky="clear-day">

<div id="sky-fx"></div>

<div class="wrap">

  <header>
    <div class="brand">
      <div class="brand-mark"></div>
      <div>
        <div class="brand-name">Skylark</div>
        <div class="brand-sub">Weather, anywhere</div>
      </div>
    </div>

    <div class="controls-row">
      <div class="search-shell">
        <div class="search-box">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="search-input" type="text" placeholder="Search a city — try London or America" autocomplete="off">
          <button class="locate-btn" id="locate-btn" title="Use my location" aria-label="Use my current location">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
          </button>
        </div>
        <div class="suggest" id="suggest"></div>
      </div>
      <div class="units-toggle" id="units-toggle">
        <button data-unit="c" class="active">°C</button>
        <button data-unit="f">°F</button>
      </div>
    </div>
  </header>

  <div class="error-box" id="error-box">
    <p id="error-text"></p>
  </div>

  <div class="state-box" id="loading-box">
    <div class="spinner"></div>
    <p>Reading the sky…</p>
  </div>

  <div class="content" id="content">

    <section class="hero">
      <div>
        <div class="hero-place"><span class="dot"></span><span id="hero-place-text">—</span></div>
        <h1 class="hero-city" id="hero-city">—</h1>
        <p class="hero-desc" id="hero-desc">—</p>
      </div>
      <div class="hero-right">
        <svg id="hero-icon" class="hero-icon" viewBox="0 0 100 100"></svg>
        <div class="hero-temp" id="hero-temp">—<sup id="hero-unit">°C</sup></div>
        <div class="hero-feels" id="hero-feels">FEELS LIKE —</div>
      </div>
    </section>

    <section class="stats" id="stats-grid"></section>

    <section>
      <div class="section-head">
        <div class="section-title">Next 24 hours</div>
        <div class="section-note" id="hourly-note">LOCAL TIME</div>
      </div>
      <div class="hourly-rail" id="hourly-rail"></div>
    </section>

    <section>
      <div class="section-head">
        <div class="section-title">7-day outlook</div>
        <div class="section-note">LOW / HIGH</div>
      </div>
      <div class="daily-list" id="daily-list"></div>
    </section>

    <div class="meta-strip">
      <span id="meta-coords">—</span>
      <span id="meta-updated">—</span>
      <span>Data: Open‑Meteo</span>
    </div>

  </div>

</div>

<script>
(function(){

  // ---------------------------------------------------------------
  // Weather-code → description / icon-key / sky-palette mapping
  // (Open-Meteo WMO codes)
  // ---------------------------------------------------------------
  const WMO = {
    0:  { text:"Clear sky",            icon:"sun",        sky:"clear" },
    1:  { text:"Mostly clear",         icon:"sun-cloud",  sky:"clear" },
    2:  { text:"Partly cloudy",        icon:"sun-cloud",  sky:"cloudy" },
    3:  { text:"Overcast",             icon:"cloud",      sky:"cloudy" },
    45: { text:"Fog",                  icon:"fog",        sky:"fog" },
    48: { text:"Icy fog",              icon:"fog",        sky:"fog" },
    51: { text:"Light drizzle",        icon:"drizzle",    sky:"rain" },
    53: { text:"Drizzle",              icon:"drizzle",    sky:"rain" },
    55: { text:"Dense drizzle",        icon:"drizzle",    sky:"rain" },
    56: { text:"Freezing drizzle",     icon:"drizzle",    sky:"rain" },
    57: { text:"Freezing drizzle",     icon:"drizzle",    sky:"rain" },
    61: { text:"Light rain",           icon:"rain",       sky:"rain" },
    63: { text:"Rain",                 icon:"rain",       sky:"rain" },
    65: { text:"Heavy rain",           icon:"rain",       sky:"rain" },
    66: { text:"Freezing rain",        icon:"rain",       sky:"rain" },
    67: { text:"Freezing rain",        icon:"rain",       sky:"rain" },
    71: { text:"Light snow",           icon:"snow",       sky:"snow" },
    73: { text:"Snow",                 icon:"snow",       sky:"snow" },
    75: { text:"Heavy snow",           icon:"snow",       sky:"snow" },
    77: { text:"Snow grains",          icon:"snow",       sky:"snow" },
    80: { text:"Light showers",        icon:"rain",       sky:"rain" },
    81: { text:"Showers",              icon:"rain",       sky:"rain" },
    82: { text:"Violent showers",      icon:"rain",       sky:"storm" },
    85: { text:"Snow showers",         icon:"snow",       sky:"snow" },
    86: { text:"Heavy snow showers",   icon:"snow",       sky:"snow" },
    95: { text:"Thunderstorm",         icon:"storm",      sky:"storm" },
    96: { text:"Thunderstorm + hail",  icon:"storm",      sky:"storm" },
    99: { text:"Severe thunderstorm",  icon:"storm",      sky:"storm" },
  };

  function wmoInfo(code){ return WMO[code] || { text:"Unknown", icon:"cloud", sky:"cloudy" }; }

  // ---------------------------------------------------------------
  // Inline SVG icon set (no external assets, theme-colored via currentColor / accent)
  // ---------------------------------------------------------------
  const ICONS = {
    "sun": `<g stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round">
      <circle cx="50" cy="50" r="18" fill="currentColor" stroke="none"/>
      <line x1="50" y1="10" x2="50" y2="20"/><line x1="50" y1="80" x2="50" y2="90"/>
      <line x1="10" y1="50" x2="20" y2="50"/><line x1="80" y1="50" x2="90" y2="50"/>
      <line x1="22" y1="22" x2="29" y2="29"/><line x1="71" y1="71" x2="78" y2="78"/>
      <line x1="78" y1="22" x2="71" y2="29"/><line x1="29" y1="71" x2="22" y2="78"/>
    </g>`,
    "sun-cloud": `<g stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="38" cy="38" r="14" fill="currentColor" stroke="none"/>
      <line x1="38" y1="10" x2="38" y2="16"/><line x1="14" y1="38" x2="20" y2="38"/>
      <line x1="18" y1="18" x2="22" y2="22"/>
      <path d="M30 68 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" fill-opacity="0.85" stroke="none"/>
    </g>`,
    "cloud": `<path d="M22 68 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" stroke="none"/>`,
    "fog": `<g stroke="currentColor" stroke-width="3.2" fill="none" stroke-linecap="round">
      <line x1="18" y1="38" x2="82" y2="38"/><line x1="12" y1="50" x2="88" y2="50"/>
      <line x1="20" y1="62" x2="80" y2="62"/>
    </g>`,
    "drizzle": `<g>
      <path d="M22 52 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" stroke="none"/>
      <g stroke="currentColor" stroke-width="2.6" stroke-linecap="round"><line x1="38" y1="68" x2="35" y2="78"/><line x1="52" y1="68" x2="49" y2="78"/><line x1="65" y1="68" x2="62" y2="78"/></g>
    </g>`,
    "rain": `<g>
      <path d="M22 50 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" stroke="none"/>
      <g stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="34" y1="66" x2="30" y2="82"/><line x1="50" y1="66" x2="46" y2="82"/><line x1="66" y1="66" x2="62" y2="82"/></g>
    </g>`,
    "snow": `<g>
      <path d="M22 46 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" stroke="none"/>
      <g stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
        <line x1="36" y1="66" x2="36" y2="82"/><line x1="29" y1="74" x2="43" y2="74"/>
        <line x1="64" y1="66" x2="64" y2="82"/><line x1="57" y1="74" x2="71" y2="74"/>
      </g>
    </g>`,
    "storm": `<g>
      <path d="M22 46 a16 16 0 1 1 4 -31 a20 20 0 0 1 38 8 a14 14 0 0 1 -4 23 z" fill="currentColor" stroke="none"/>
      <polygon points="52,62 40,80 50,80 44,94 64,72 53,72" fill="currentColor" stroke="none"/>
    </g>`,
  };

  function iconSvg(key){ return ICONS[key] || ICONS.cloud; }
  function setIcon(el, key){ el.innerHTML = iconSvg(key); }

  // ---------------------------------------------------------------
  // Sky background fx: lightweight ambient particles per condition
  // ---------------------------------------------------------------
  const fx = document.getElementById('sky-fx');
  let fxRaf = null;
  function clearFx(){
    if (fxRaf) cancelAnimationFrame(fxRaf);
    fx.innerHTML = '';
  }
  function buildRain(count, snow){
    clearFx();
    const drops = [];
    for(let i=0;i<count;i++){
      const d = document.createElement('div');
      const x = Math.random()*100;
      const delay = Math.random()*4;
      const dur = snow ? (6+Math.random()*5) : (0.6+Math.random()*0.5);
      const size = snow ? (2+Math.random()*3) : 1.4;
      const len = snow ? size : (10+Math.random()*10);
      d.style.position='absolute';
      d.style.left = x+'%';
      d.style.top='-20px';
      d.style.width = (snow? size : 1.6)+'px';
      d.style.height = (snow? size : len)+'px';
      d.style.borderRadius = snow ? '50%' : '2px';
      d.style.background = snow ? 'rgba(255,255,255,0.85)' : 'rgba(255,255,255,0.35)';
      d.style.opacity = snow ? '0.8' : '0.5';
      d.style.transform = 'translateY(0)';
      d.style.animation = `fall ${dur}s linear ${delay}s infinite`;
      fx.appendChild(d);
    }
    if(!document.getElementById('fall-kf')){
      const style = document.createElement('style');
      style.id='fall-kf';
      style.textContent = `@keyframes fall{ from{transform:translateY(-10vh);} to{transform:translateY(110vh);} }`;
      document.head.appendChild(style);
    }
  }
  function buildFog(){
    clearFx();
    for(let i=0;i<3;i++){
      const band = document.createElement('div');
      band.style.position='absolute';
      band.style.left='-20%'; band.style.width='140%';
      band.style.top = (20+i*25)+'%';
      band.style.height='120px';
      band.style.background = 'linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent)';
      band.style.filter='blur(8px)';
      band.style.animation = `drift ${20+i*6}s linear infinite`;
      fx.appendChild(band);
    }
    if(!document.getElementById('drift-kf')){
      const style = document.createElement('style');
      style.id='drift-kf';
      style.textContent = `@keyframes drift{ from{transform:translateX(0);} to{transform:translateX(30%);} }`;
      document.head.appendChild(style);
    }
  }
  function setSkyFx(sky){
    if(sky==='rain' || sky==='storm') buildRain(46,false);
    else if(sky==='snow') buildRain(60,true);
    else if(sky==='fog') buildFog();
    else clearFx();
  }

  // ---------------------------------------------------------------
  // State
  // ---------------------------------------------------------------
  let unit = 'c'; // c | f
  let lastData = null; // cached full payload for unit re-render

  const el = (id)=>document.getElementById(id);
  const loadingBox = el('loading-box');
  const content = el('content');
  const errorBox = el('error-box');
  const errorText = el('error-text');

  function showLoading(){
    loadingBox.style.display='block';
    content.classList.remove('show');
    errorBox.classList.remove('show');
  }
  function showError(msg){
    loadingBox.style.display='none';
    content.classList.remove('show');
    errorBox.classList.add('show');
    errorText.textContent = msg;
  }
  function showContent(){
    loadingBox.style.display='none';
    errorBox.classList.remove('show');
    content.classList.add('show');
  }

  function cToF(c){ return c*9/5+32; }
  function fmtTemp(c){
    const v = unit==='c' ? c : cToF(c);
    return Math.round(v);
  }
  function unitLabel(){ return unit==='c' ? '°C' : '°F'; }

  function dayPart(hour){ return hour>=6 && hour<19; }

  function skyFromCode(code, hour){
    const info = wmoInfo(code);
    if(info.sky==='clear') return dayPart(hour) ? 'clear-day' : 'clear-night';
    return info.sky;
  }

  // ---------------------------------------------------------------
  // Geocoding (Open-Meteo geocoding API — handles "London", "America"→
  // best-guess "United States" style queries, etc.)
  // ---------------------------------------------------------------
  async function geocode(query){
    const url = `https://geocoding-api.open-meteo.com/v1/search?name=${encodeURIComponent(query)}&count=8&language=en&format=json`;
    const res = await fetch(url);
    if(!res.ok) throw new Error('Geocoding service unavailable');
    const data = await res.json();
    return data.results || [];
  }

  async function reverseGeocode(lat, lon){
    // Open-Meteo's geocoding API doesn't do reverse lookup, so we ask the
    // weather endpoint for the place via a light Nominatim-free fallback:
    // we just label it with coordinates if no name service is available.
    try{
      const url = `https://geocoding-api.open-meteo.com/v1/search?name=${lat},${lon}`;
      const res = await fetch(url);
      if(res.ok){
        const d = await res.json();
        if(d.results && d.results.length) return d.results[0];
      }
    }catch(e){}
    return null;
  }

  // ---------------------------------------------------------------
  // Weather fetch
  // ---------------------------------------------------------------
  async function fetchWeather(lat, lon, tz){
    const params = new URLSearchParams({
      latitude: lat,
      longitude: lon,
      current: 'temperature_2m,apparent_temperature,relative_humidity_2m,weather_code,wind_speed_10m,wind_direction_10m,pressure_msl,uv_index,is_day',
      hourly: 'temperature_2m,weather_code,precipitation_probability',
      daily: 'weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,sunrise,sunset',
      timezone: tz || 'auto',
      forecast_days: '7',
    });
    const res = await fetch(`https://api.open-meteo.com/v1/forecast?${params.toString()}`);
    if(!res.ok) throw new Error('Forecast service unavailable');
    return res.json();
  }

  // ---------------------------------------------------------------
  // Render
  // ---------------------------------------------------------------
  function renderAll(place, weather){
    lastData = { place, weather };

    const cur = weather.current;
    const code = cur.weather_code;
    const info = wmoInfo(code);
    const hourNow = new Date(cur.time).getHours();
    const sky = skyFromCode(code, hourNow);

    document.body.setAttribute('data-sky', sky);
    setSkyFx(sky);

    // header / hero
    const placeLabel = [place.name, place.admin1, place.country].filter(Boolean);
    // avoid duplicate when admin1 === name
    const uniqueParts = [];
    placeLabel.forEach(p=>{ if(!uniqueParts.includes(p)) uniqueParts.push(p); });
    el('hero-place-text').textContent = uniqueParts.slice(1).join(', ') || (place.country || '—');
    el('hero-city').textContent = place.name;
    el('hero-desc').textContent = `${info.text}. ${describeWind(cur.wind_speed_10m)} ${describeHumidity(cur.relative_humidity_2m)}`;
    setIcon(el('hero-icon'), info.icon);
    el('hero-temp').childNodes[0].nodeValue = fmtTemp(cur.temperature_2m);
    el('hero-unit').textContent = unitLabel();
    el('hero-feels').textContent = `FEELS LIKE ${fmtTemp(cur.apparent_temperature)}${unitLabel()}`;

    // stats grid
    const statsGrid = el('stats-grid');
    statsGrid.innerHTML = '';
    const stats = [
      { label:'Humidity', value: `${Math.round(cur.relative_humidity_2m)}<span>%</span>` },
      { label:'Wind', value: `${Math.round(cur.wind_speed_10m)}<span>km/h</span>` },
      { label:'Pressure', value: `${Math.round(cur.pressure_msl)}<span>hPa</span>` },
      { label:'UV index', value: `${cur.uv_index!=null ? Math.round(cur.uv_index) : '—'}` },
    ];
    stats.forEach(s=>{
      const div = document.createElement('div');
      div.className='stat';
      div.innerHTML = `<div class="stat-label">${s.label}</div><div class="stat-value">${s.value}</div>`;
      statsGrid.appendChild(div);
    });

    // hourly rail — next 24 hrs starting from current hour
    const rail = el('hourly-rail');
    rail.innerHTML = '';
    const nowISO = cur.time;
    let startIdx = weather.hourly.time.findIndex(t => t >= nowISO);
    if(startIdx < 0) startIdx = 0;
    for(let i=startIdx; i<startIdx+24 && i<weather.hourly.time.length; i++){
      const t = new Date(weather.hourly.time[i]);
      const hc = weather.hourly.weather_code[i];
      const hinfo = wmoInfo(hc);
      const card = document.createElement('div');
      card.className='hour-card';
      const label = i===startIdx ? 'Now' : t.toLocaleTimeString([], {hour:'numeric'});
      card.innerHTML = `<div class="t">${label}</div><svg viewBox="0 0 100 100">${iconSvg(hinfo.icon)}</svg><div class="v">${fmtTemp(weather.hourly.temperature_2m[i])}°</div>`;
      rail.appendChild(card);
    }

    // daily list
    const dailyList = el('daily-list');
    dailyList.innerHTML = '';
    const days = weather.daily.time;
    const highs = weather.daily.temperature_2m_max;
    const lows = weather.daily.temperature_2m_min;
    const codes = weather.daily.weather_code;
    const globalMax = Math.max(...highs);
    const globalMin = Math.min(...lows);
    const span = (globalMax - globalMin) || 1;

    days.forEach((d, i)=>{
      const date = new Date(d + 'T00:00:00');
      const dayName = i===0 ? 'Today' : date.toLocaleDateString([], { weekday:'short' });
      const dateSub = date.toLocaleDateString([], { month:'short', day:'numeric' });
      const dinfo = wmoInfo(codes[i]);
      const hi = fmtTemp(highs[i]);
      const lo = fmtTemp(lows[i]);
      const leftPct = ((lows[i]-globalMin)/span)*100;
      const widthPct = ((highs[i]-lows[i])/span)*100;

      const row = document.createElement('div');
      row.className='day-row';
      row.innerHTML = `
        <div class="day-name">${dayName}<span class="sub">${dateSub}</span></div>
        <svg viewBox="0 0 100 100">${iconSvg(dinfo.icon)}</svg>
        <div class="day-bar-track"><div class="day-bar-fill" style="left:${leftPct}%;width:${Math.max(widthPct,6)}%"></div></div>
        <div class="day-lo">${lo}°</div>
        <div class="day-hi">${hi}°</div>
      `;
      dailyList.appendChild(row);
    });

    // meta
    el('meta-coords').textContent = `${place.latitude.toFixed(2)}°, ${place.longitude.toFixed(2)}°`;
    el('meta-updated').textContent = `Updated ${new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}`;

    showContent();
  }

  function describeWind(speed){
    if(speed < 5) return 'Air is calm.';
    if(speed < 20) return 'A light breeze is moving through.';
    if(speed < 40) return 'Winds are noticeably brisk.';
    return 'Strong winds right now.';
  }
  function describeHumidity(h){
    if(h>80) return 'Humidity is high.';
    if(h<30) return 'Air is dry.';
    return '';
  }

  function rerenderUnitOnly(){
    if(lastData) renderAll(lastData.place, lastData.weather);
  }

  // ---------------------------------------------------------------
  // Search flow
  // ---------------------------------------------------------------
  async function loadForPlace(place){
    showLoading();
    try{
      const weather = await fetchWeather(place.latitude, place.longitude, place.timezone);
      renderAll(place, weather);
    }catch(err){
      showError(`Couldn't load weather for ${place.name}. ${err.message || ''}`);
    }
  }

  async function searchAndLoad(query){
    showLoading();
    try{
      const results = await geocode(query);
      if(!results.length){
        showError(`No place found matching "${query}". Try a city name, like "London" or "New York".`);
        return;
      }
      // Prefer exact-ish country/city matches; otherwise take top hit.
      const best = results[0];
      await loadForPlace(best);
    }catch(err){
      showError(err.message || 'Something went wrong fetching that location.');
    }
  }

  // typeahead suggestions
  const searchInput = el('search-input');
  const suggestBox = el('suggest');
  let debounceTimer = null;

  searchInput.addEventListener('input', ()=>{
    const q = searchInput.value.trim();
    clearTimeout(debounceTimer);
    if(q.length < 2){ suggestBox.classList.remove('show'); suggestBox.innerHTML=''; return; }
    debounceTimer = setTimeout(async ()=>{
      try{
        const results = await geocode(q);
        if(!results.length){ suggestBox.classList.remove('show'); suggestBox.innerHTML=''; return; }
        suggestBox.innerHTML = '';
        results.slice(0,6).forEach(r=>{
          const btn = document.createElement('button');
          const parts = [r.name, r.admin1, r.country].filter(Boolean);
          const unique = []; parts.forEach(p=>{ if(!unique.includes(p)) unique.push(p); });
          btn.innerHTML = `${unique[0]}<span class="muted">${unique.slice(1).join(', ')}</span>`;
          btn.addEventListener('click', ()=>{
            searchInput.value = unique[0];
            suggestBox.classList.remove('show');
            loadForPlace(r);
          });
          suggestBox.appendChild(btn);
        });
        suggestBox.classList.add('show');
      }catch(e){ /* silent for typeahead */ }
    }, 320);
  });

  searchInput.addEventListener('keydown', (e)=>{
    if(e.key==='Enter'){
      const q = searchInput.value.trim();
      if(q){ suggestBox.classList.remove('show'); searchAndLoad(q); }
    }
  });

  document.addEventListener('click', (e)=>{
    if(!suggestBox.contains(e.target) && e.target!==searchInput){
      suggestBox.classList.remove('show');
    }
  });

  // geolocation
  el('locate-btn').addEventListener('click', ()=>{
    if(!navigator.geolocation){
      showError('Geolocation is not supported by this browser.');
      return;
    }
    showLoading();
    navigator.geolocation.getCurrentPosition(async (pos)=>{
      const { latitude, longitude } = pos.coords;
      const place = await reverseGeocode(latitude, longitude);
      const finalPlace = place || { name:'Your location', latitude, longitude, country:'', admin1:'' };
      finalPlace.latitude = latitude; finalPlace.longitude = longitude;
      loadForPlace(finalPlace);
    }, (err)=>{
      showError('Could not get your location. Please allow location access or search for a city instead.');
    }, { timeout:10000 });
  });

  // units toggle
  document.getElementById('units-toggle').addEventListener('click', (e)=>{
    const btn = e.target.closest('button[data-unit]');
    if(!btn) return;
    unit = btn.getAttribute('data-unit');
    document.querySelectorAll('#units-toggle button').forEach(b=>b.classList.toggle('active', b===btn));
    rerenderUnitOnly();
  });

  // ---------------------------------------------------------------
  // Initial load: try geolocation silently, else default to London
  // ---------------------------------------------------------------
  function init(){
    if(navigator.geolocation){
      navigator.geolocation.getCurrentPosition(async (pos)=>{
        const { latitude, longitude } = pos.coords;
        const place = await reverseGeocode(latitude, longitude);
        const finalPlace = place || { name:'Your location', latitude, longitude, country:'', admin1:'' };
        finalPlace.latitude = latitude; finalPlace.longitude = longitude;
        loadForPlace(finalPlace);
      }, ()=>{
        searchAndLoad('London');
      }, { timeout:6000 });
    } else {
      searchAndLoad('London');
    }
  }

  init();
})();
</script>
</body>
</html>