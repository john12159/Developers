<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BazaarHub - India Shopping Directory & Deals Board</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<style>
    :root {
    --bg-primary: #0b0f19;
    --bg-surface: #131a26;
    --bg-surface-hover: #1c2536;
    --text-main: #f1f5f9;
    --text-muted: #94a3b8;
    --primary-color: #f97316;
    --primary-hover: #ea580c;
    --border-color: #1e293b;
    --fashion-theme: #38bdf8;
    --electronics-theme: #34d399;
    --home-theme: #a78bfa;
    --beauty-theme: #f472b6;
    --grocery-theme: #4ade80;
    --kids-theme: #fbbf24;
    --other-theme: #94a3b8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
body {
    font-family: ui-sans-serif, system-ui, sans-serif;
    background-color: var(--bg-primary);
    color: var(--text-main);
    line-height: 1.5;
}

/* Navigation layout */
.navbar {
    background-color: var(--bg-surface);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 50;
}
.nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.logo { font-size: 1.25rem; font-weight: 700; color: #fff; text-decoration: none; }
.logo i { color: var(--primary-color); }
.nav-actions { display: flex; gap: 0.75rem; }

/* Buttons global definition */
.btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.375rem;
    font-weight: 500;
    cursor: pointer;
    font-size: 0.875rem;
    border: 1px solid transparent;
    transition: all 0.15s ease;
}
.btn-primary { background-color: var(--primary-color); color: #fff; }
.btn-primary:hover { background-color: var(--primary-hover); }
.btn-secondary { background-color: #1e293b; color: var(--text-main); border-color: var(--border-color); }
.btn-secondary:hover { background-color: #334155; }
.btn-outline-sm { background: transparent; border-color: var(--border-color); color: var(--text-muted); padding: 0.35rem 0.75rem; font-size: 0.8rem; }
.btn-outline-sm:hover { color: #fff; border-color: #64748b; }
.btn-block { width: 100%; display: block; margin-top: 1rem; }
.btn:disabled { opacity: 0.6; cursor: not-allowed; }

/* Hero Branding Layout */
.hero { background: radial-gradient(circle at top right, #431407, var(--bg-primary)); padding: 4rem 1.5rem; text-align: center; border-bottom: 1px solid var(--border-color); }
.hero-container { max-width: 700px; margin: 0 auto; }
.announcement { display: inline-block; background: #1e293b; color: #cbd5e1; font-size: 0.75rem; font-weight: 500; padding: 0.25rem 0.75rem; border-radius: 9999px; margin-bottom: 1rem; border: 1px solid var(--border-color); }
.hero h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.05em; margin-bottom: 1rem; }
.hero p { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2.5rem; }

/* Filter Console */
.search-filter-wrapper { display: flex; background: var(--bg-surface); padding: 0.5rem; border-radius: 0.5rem; gap: 0.5rem; border: 1px solid var(--border-color); }
.search-box { display: flex; align-items: center; flex: 3; padding-left: 0.75rem; color: var(--text-muted); }
.search-box input { width: 100%; background: transparent; border: none; padding: 0.5rem; font-size: 1rem; outline: none; color: white; }
.select-box { flex: 1; border-left: 1px solid var(--border-color); }
.select-box select { width: 100%; background: transparent; border: none; padding: 0.5rem; color: var(--text-main); outline: none; cursor: pointer; }
.select-box select option { background-color: var(--bg-surface); color: white; }

/* Content Grid / Tab switcher layout */
.main-container { max-width: 1200px; margin: 2rem auto; padding: 0 1.5rem; min-height: 50vh; }
.view-switcher { display: flex; gap: 1.5rem; border-bottom: 1px solid var(--border-color); margin-bottom: 2rem; }
.tab-btn { background: none; border: none; padding: 1rem 0.25rem; font-size: 1rem; color: var(--text-muted); cursor: pointer; display: flex; align-items: center; gap: 0.5rem; position: relative; font-weight: 500; }
.tab-btn.active { color: white; font-weight: 600; }
.tab-btn.active::after { content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 2px; background-color: var(--primary-color); }
.counter { background-color: #1e293b; color: var(--text-main); font-size: 0.75rem; padding: 0.1rem 0.5rem; border-radius: 0.25rem; margin-left: 0.25rem; }

/* Elements Execution Views */
.content-view { display: none; }
.content-view.active { display: block; }
.grid-layout { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }

/* Application Component Cards Architecture */
.card { background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.5rem; padding: 1.5rem; display: flex; flex-direction: column; justify-content: space-between; transition: all 0.2s ease; position: relative; }
.card:hover { transform: translateY(-2px); background-color: var(--bg-surface-hover); border-color: #334155; }
.card h3 { margin: 0.75rem 0 0.5rem 0; font-size: 1.15rem; }
.card p { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1; }
.card-header-meta { display: flex; justify-content: space-between; align-items: center; }
.card-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid var(--border-color); padding-top: 1rem; margin-top: auto; }
.card-link { color: var(--primary-color); text-decoration: none; font-size: 0.875rem; font-weight: 500; }
.card-link:hover { text-decoration: underline; }
.card-link.disabled { color: var(--text-muted); cursor: default; pointer-events: none; }

/* Badges and Specialties tracking */
.badge-ui { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 0.25rem; }
.badge-ui.verified { background-color: rgba(52, 211, 153, 0.1); color: var(--electronics-theme); }
.badge-ui.new { background-color: rgba(244, 63, 94, 0.1); color: #f43f5e; }
.tag-lbl { font-size: 0.75rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 0.25rem; color: #fff; }
.tag-fashion { background-color: rgba(56, 189, 248, 0.2); color: var(--fashion-theme); }
.tag-electronics { background-color: rgba(52, 211, 153, 0.2); color: var(--electronics-theme); }
.tag-home { background-color: rgba(167, 139, 250, 0.2); color: var(--home-theme); }
.tag-beauty { background-color: rgba(244, 114, 182, 0.2); color: var(--beauty-theme); }
.tag-grocery { background-color: rgba(74, 222, 128, 0.2); color: var(--grocery-theme); }
.tag-kids { background-color: rgba(251, 191, 36, 0.2); color: var(--kids-theme); }
.tag-other { background-color: rgba(148, 163, 184, 0.2); color: var(--other-theme); }

/* Unified Deals/Listings System Row layout */
.list-layout { display: flex; flex-direction: column; gap: 1rem; }
.job-row { background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.5rem; padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; transition: all 0.2s ease; }
.job-row:hover { background-color: var(--bg-surface-hover); border-color: #334155; }
.job-left { display: flex; align-items: center; gap: 1rem; }
.company-avatar { width: 44px; height: 44px; background: #1e293b; border-radius: 0.375rem; display: flex; align-items: center; justify-content: center; font-weight: 700; color: white; border: 1px solid var(--border-color); overflow: hidden; }
.company-avatar img { width: 100%; height: 100%; object-fit: contain; }
.company-info p { color: var(--text-muted); font-size: 0.85rem; }
.job-right { display: flex; align-items: center; gap: 1.5rem; }
.meta-detail { font-size: 0.85rem; color: var(--text-muted); display: flex; align-items: center; gap: 0.25rem; }
.price-now { color: #4ade80; font-weight: 700; }
.price-was { color: var(--text-muted); text-decoration: line-through; font-size: 0.8rem; margin-left: 4px; }

/* Status / info banners */
.status-banner { display: flex; align-items: center; gap: 0.6rem; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.5rem; padding: 0.85rem 1rem; margin-bottom: 1.25rem; font-size: 0.85rem; color: var(--text-muted); }
.status-banner i { color: var(--primary-color); }

/* Modals Core Overlay Framework */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; z-index: 1000; padding: 1rem; }
.modal-overlay.active { display: flex; }
.modal-box { background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.75rem; width: 100%; max-width: 480px; padding: 1.5rem; position: relative; animation: modalSlide 0.2s cubic-bezier(0.16, 1, 0.3, 1); max-height: 90vh; overflow-y: auto; }
@keyframes modalSlide { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
.close-btn { background: none; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; }
.close-btn:hover { color: white; }

/* Programmatic Forms Integration */
.form-group { margin-bottom: 1.2rem; }
.form-group label { display: block; font-size: 0.85rem; color: var(--text-muted); margin-bottom: 0.4rem; font-weight: 500; }
.form-group input, .form-group textarea, .form-group select { width: 100%; background: var(--bg-primary); border: 1px solid var(--border-color); padding: 0.625rem; border-radius: 0.375rem; color: white; outline: none; font-size: 0.9rem; }
.form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--primary-color); }
.form-group .field-error { color: #f43f5e; font-size: 0.75rem; margin-top: 0.3rem; display: none; }
.form-group.invalid input, .form-group.invalid textarea { border-color: #f43f5e; }
.form-group.invalid .field-error { display: block; }
.form-row { display: flex; gap: 1rem; }
.form-row .form-group { flex: 1; }

.site-footer { text-align: center; padding: 4rem 1rem; color: var(--text-muted); font-size: 0.85rem; border-top: 1px solid var(--border-color); margin-top: 5rem; }

@media(max-width: 768px) {
    .search-filter-wrapper { flex-direction: column; }
    .select-box { border-left: none; border-top: 1px solid var(--border-color); padding-top: 0.5rem; }
    .job-row { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .job-right { width: 100%; justify-content: space-between; border-top: 1px solid var(--border-color); padding-top: 0.75rem; flex-wrap: wrap; }
}

</style>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="#" class="logo"><i class="fa-solid fa-bag-shopping"></i> BazaarHub India</a>
            <div class="nav-actions">
                <button class="btn btn-secondary" onclick="toggleModal('sellerModal')"><i class="fa-solid fa-plus"></i> List Your Shop</button>
                <button class="btn btn-primary" onclick="toggleModal('dealModal')"><i class="fa-solid fa-tag"></i> Post a Deal</button>
            </div>
        </div>
    </nav>

    <!-- Hero Header -->
    <header class="hero">
        <div class="hero-container">
            <span class="announcement">🇮🇳 Curated by sellers, for shoppers across India</span>
            <h1>The India Shopping Directory</h1>
            <p>Discover trusted independent sellers and the deals they're running right now — every link goes straight to the seller.</p>

            <div class="search-filter-wrapper">
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="search-input" placeholder="Search shops, deals, cities...">
                </div>
                <div class="select-box">
                    <select id="category-filter">
                        <option value="all">All Categories</option>
                        <option value="fashion">Fashion</option>
                        <option value="electronics">Electronics</option>
                        <option value="home">Home & Living</option>
                        <option value="beauty">Beauty & Personal Care</option>
                        <option value="grocery">Grocery</option>
                        <option value="kids">Kids & Baby</option>
                        <option value="other">Other</option>
                    </select>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Workspace -->
    <main class="main-container">

        <!-- Tab Switcher System -->
        <div class="view-switcher">
            <button class="tab-btn active" id="tab-directory" onclick="switchView('directory')">
                <i class="fa-solid fa-store"></i> Seller Directory <span class="counter" id="directory-count">0</span>
            </button>
            <button class="tab-btn" id="tab-jobs" onclick="switchView('jobs')">
                <i class="fa-solid fa-tags"></i> Active Deals <span class="counter" id="jobs-count">0</span>
            </button>
        </div>

        <!-- Dynamic View Sections -->
        <section id="directory-view" class="content-view active">
            <div class="grid-layout" id="directory-container">
                <!-- JavaScript automatically populates here -->
            </div>
        </section>

        <section id="jobs-view" class="content-view">
            <div id="jobs-status-area"></div>
            <div class="list-layout" id="jobs-container">
                <!-- JavaScript automatically populates here -->
            </div>
        </section>
    </main>

    <!-- MODAL 1: List Your Shop -->
    <div class="modal-overlay" id="sellerModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>List Your Shop</h3>
                <button class="close-btn" onclick="toggleModal('sellerModal')">&times;</button>
            </div>
            <form id="sellerForm">
                <div class="form-group">
                    <label>Shop Name</label>
                    <input type="text" id="shopName" required placeholder="e.g. Jaipur Handloom Co.">
                </div>
                <div class="form-group">
                    <label>Store URL</label>
                    <input type="url" id="shopUrl" required placeholder="https://yourshop.com or Instagram/WhatsApp catalog link">
                    <span class="field-error">Enter a valid URL starting with http:// or https://</span>
                </div>
                <div class="form-group">
                    <label>Description</label>
                    <textarea id="shopDesc" rows="3" required placeholder="What do you sell? What makes your shop worth visiting?"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Category</label>
                        <select id="shopCat">
                            <option value="fashion">Fashion</option>
                            <option value="electronics">Electronics</option>
                            <option value="home">Home & Living</option>
                            <option value="beauty">Beauty & Personal Care</option>
                            <option value="grocery">Grocery</option>
                            <option value="kids">Kids & Baby</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Base City</label>
                        <input type="text" id="shopCity" required placeholder="e.g. Jaipur, Rajasthan">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Add My Shop</button>
            </form>
        </div>
    </div>

    <!-- MODAL 2: Post a Deal -->
    <div class="modal-overlay" id="dealModal">
        <div class="modal-box">
            <div class="modal-header">
                <h3>Post an Active Deal</h3>
                <button class="close-btn" onclick="toggleModal('dealModal')">&times;</button>
            </div>
            <form id="dealForm">
                <div class="form-group">
                    <label>Deal Title</label>
                    <input type="text" id="dealTitle" required placeholder="e.g. Flat 40% off festive kurtas">
                </div>
                <div class="form-group">
                    <label>Shop / Seller Name</label>
                    <input type="text" id="dealShop" required placeholder="e.g. Jaipur Handloom Co.">
                </div>
                <div class="form-group">
                    <label>Product / Deal URL</label>
                    <input type="url" id="dealUrl" required placeholder="https://yourshop.com/product/kurta-set">
                    <span class="field-error">Enter a valid URL starting with http:// or https://</span>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Category</label>
                        <select id="dealCat">
                            <option value="fashion">Fashion</option>
                            <option value="electronics">Electronics</option>
                            <option value="home">Home & Living</option>
                            <option value="beauty">Beauty & Personal Care</option>
                            <option value="grocery">Grocery</option>
                            <option value="kids">Kids & Baby</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Price Now (₹)</label>
                        <input type="text" id="dealPriceNow" required placeholder="e.g. ₹899">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Original Price (₹) — optional</label>
                        <input type="text" id="dealPriceWas" placeholder="e.g. ₹1,499">
                    </div>
                    <div class="form-group">
                        <label>Ships To</label>
                        <input type="text" id="dealLoc" required placeholder="e.g. Pan-India">
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Publish Deal</button>
            </form>
        </div>
    </div>

    <footer class="site-footer">
        <p>&copy; 2026 BazaarHub India. Every listing is added manually by sellers — no scraped or simulated data. Saved locally in this browser.</p>
    </footer>

    <script>
// =========================================================================
// PART 1: CORE STATE
// =========================================================================
// This is a fully manual directory: sellers list their own shop, and post
// their own deals. There is no live third-party API here — we intentionally
// avoid faking a "live feed" with placeholder data, since no free, real,
// India-specific deals API exists without a paid affiliate key. If you have
// one (Amazon/Flipkart affiliate, EarnKaro, etc.), this is the function to
// extend: fetchLiveExternalDeals().

let directoryData = loadFromStorage('bazaar_directory', [
    { id: 1, name: "Jaipur Handloom Co.", desc: "Hand-block-printed cotton kurtas and home textiles, woven by artisan collectives in Rajasthan.", cat: "fashion", city: "Jaipur, Rajasthan", url: "https://www.jaipurhandloom.com" },
    { id: 2, name: "TechBazaar Bengaluru", desc: "Refurbished laptops and accessories with 6-month warranty, tested and certified in-house.", cat: "electronics", city: "Bengaluru, Karnataka", url: "https://www.flipkart.com" },
    { id: 3, name: "Kerala Spice Trail", desc: "Single-origin spices, coffee, and tea sourced directly from Wayanad and Idukki estates.", cat: "grocery", city: "Kochi, Kerala", url: "https://www.bigbasket.com" }
]);

let localDealsData = loadFromStorage('bazaar_deals', [
    { id: 101, title: "Flat 30% off monsoon kurta sets", shop: "Jaipur Handloom Co.", cat: "fashion", priceNow: "₹1,049", priceWas: "₹1,499", loc: "Pan-India", url: "https://www.jaipurhandloom.com/collections/sale" }
]);

let jobsData = [...localDealsData];

function loadFromStorage(key, fallback) {
    try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
    } catch (e) {
        console.warn(`Could not read ${key} from storage, using defaults.`, e);
        return fallback;
    }
}

function saveToStorage(key, value) {
    try {
        localStorage.setItem(key, JSON.stringify(value));
    } catch (e) {
        console.warn(`Could not persist ${key} to storage.`, e);
    }
}

function compileMasterState() {
    jobsData = [...localDealsData];
    updateCounterBadges();
    rebuildCategoryDropdown();
    executeLiveSearchFiltering();
}

function renderStatusBanner(message) {
    const area = document.getElementById('jobs-status-area');
    if (!area) return;
    area.innerHTML = message
        ? `<div class="status-banner"><i class="fa-solid fa-circle-info"></i><span>${message}</span></div>`
        : '';
}

// =========================================================================
// PART 2: UI SWITCHERS & DYNAMIC HTML DOM INJECTION ENGINES
// =========================================================================

function switchView(viewName) {
    document.querySelectorAll('.content-view').forEach(view => view.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));

    const viewTarget = document.getElementById(`${viewName}-view`);
    const tabTarget = document.getElementById(`tab-${viewName}`);

    if (viewTarget) viewTarget.classList.add('active');
    if (tabTarget) tabTarget.classList.add('active');
}

function toggleModal(modalId) {
    const elementModal = document.getElementById(modalId);
    if (elementModal) {
        elementModal.classList.toggle('active');
    }
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
}

const CATEGORY_LABELS = {
    fashion: 'Fashion',
    electronics: 'Electronics',
    home: 'Home & Living',
    beauty: 'Beauty & Personal Care',
    grocery: 'Grocery',
    kids: 'Kids & Baby',
    other: 'Other'
};

/**
 * UI Builder: Populates the Seller Directory Grid
 */
function renderToolDirectoryGrid(arrayData) {
    const container = document.getElementById('directory-container');
    if (!container) return;

    container.innerHTML = '';

    if (arrayData.length === 0) {
        container.innerHTML = `<div class="card" style="grid-column: 1/-1; text-align:center; padding:3rem; color:var(--text-muted)">No sellers match your active filter.</div>`;
        return;
    }

    arrayData.forEach(shop => {
        const itemCard = document.createElement('div');
        itemCard.className = 'card';
        const safeUrl = escapeHtml(shop.url || '');
        const linkHtml = shop.url
            ? `<a href="${safeUrl}" target="_blank" rel="noopener noreferrer" class="card-link">Visit Store <i class="fa-solid fa-arrow-up-right-from-square"></i></a>`
            : `<span class="card-link disabled">No link provided</span>`;
        itemCard.innerHTML = `
            <div class="card-header-meta">
                <span class="tag-lbl tag-${shop.cat}">${escapeHtml((CATEGORY_LABELS[shop.cat] || shop.cat).toUpperCase())}</span>
                <span class="badge-ui verified"><i class="fa-solid fa-location-dot"></i> ${escapeHtml(shop.city)}</span>
            </div>
            <h3>${escapeHtml(shop.name)}</h3>
            <p>${escapeHtml(shop.desc)}</p>
            <div class="card-footer">
                ${linkHtml}
                <button class="btn btn-outline-sm" onclick="removeResourceElement(${shop.id}, 'directory')"><i class="fa-solid fa-trash"></i></button>
            </div>
        `;
        container.appendChild(itemCard);
    });
}

/**
 * UI Builder: Renders the Active Deals list — every entry posted manually
 * by a seller, every link a real destination to that seller's page.
 */
function renderLiveJobFeedList(arrayData) {
    const container = document.getElementById('jobs-container');
    if (!container) return;

    container.innerHTML = '';

    if (arrayData.length === 0) {
        container.innerHTML = `<div class="job-row" style="justify-content:center; padding:3rem; color:var(--text-muted)">No active deals match this search yet.</div>`;
        return;
    }

    arrayData.forEach(deal => {
        const rowNode = document.createElement('div');
        rowNode.className = 'job-row';

        rowNode.innerHTML = `
            <div class="job-left">
                <div class="company-avatar">
                    ${escapeHtml(deal.shop.charAt(0))}
                </div>
                <div class="company-info">
                    <h3>${escapeHtml(deal.title)}</h3>
                    <p>${escapeHtml(deal.shop)} •
                        <span class="tag-lbl tag-${deal.cat}" style="font-size:0.65rem; padding:0.1rem 0.3rem">${escapeHtml(CATEGORY_LABELS[deal.cat] || deal.cat)}</span>
                    </p>
                </div>
            </div>
            <div class="job-right">
                <span class="meta-detail"><i class="fa-solid fa-truck"></i> ${escapeHtml(deal.loc)}</span>
                <span class="meta-detail">
                    <span class="price-now">${escapeHtml(deal.priceNow)}</span>
                    ${deal.priceWas ? `<span class="price-was">${escapeHtml(deal.priceWas)}</span>` : ''}
                </span>

                <a href="${escapeHtml(deal.url)}" target="_blank" rel="noopener noreferrer"
                   class="btn btn-sm btn-primary" style="text-decoration:none">
                    Grab Deal <i class="fa-solid fa-arrow-up-right-from-square" style="font-size:0.7rem; margin-left:4px"></i>
                </a>

                <button class="btn btn-outline-sm" onclick="removeResourceElement(${deal.id}, 'jobs')"><i class="fa-solid fa-trash"></i></button>
            </div>
        `;
        container.appendChild(rowNode);
    });
}

// =========================================================================
// PART 3: REACTIVE COMPUTATIONS, INTERCEPTORS & INITIALIZATION
// =========================================================================

function executeLiveSearchFiltering() {
    const rawSearchBox = document.getElementById('search-input');
    const rawFilterDropdown = document.getElementById('category-filter');

    const searchString = rawSearchBox ? rawSearchBox.value.toLowerCase() : '';
    const selectedCategory = rawFilterDropdown ? rawFilterDropdown.value : 'all';

    const directoryResult = directoryData.filter(item => {
        const matchesQuery = item.name.toLowerCase().includes(searchString) || item.desc.toLowerCase().includes(searchString) || item.city.toLowerCase().includes(searchString);
        const matchesCategory = selectedCategory === 'all' || item.cat === selectedCategory;
        return matchesQuery && matchesCategory;
    });

    const dealsResult = jobsData.filter(deal => {
        const matchesQuery = deal.title.toLowerCase().includes(searchString) || deal.shop.toLowerCase().includes(searchString) || deal.loc.toLowerCase().includes(searchString);
        const matchesCategory = selectedCategory === 'all' || deal.cat === selectedCategory;
        return matchesQuery && matchesCategory;
    });

    renderToolDirectoryGrid(directoryResult);
    renderLiveJobFeedList(dealsResult);
}

function updateCounterBadges() {
    const dBadge = document.getElementById('directory-count');
    const jBadge = document.getElementById('jobs-count');

    if (dBadge) dBadge.textContent = directoryData.length;
    if (jBadge) jBadge.textContent = jobsData.length;
}

/**
 * Rebuilds the category dropdown so option labels reflect live counts
 * across both Seller Directory and Active Deals combined.
 */
function rebuildCategoryDropdown() {
    const dropCategory = document.getElementById('category-filter');
    if (!dropCategory) return;

    const previousSelection = dropCategory.value || 'all';

    const counts = {};
    Object.keys(CATEGORY_LABELS).forEach(key => { counts[key] = 0; });
    directoryData.forEach(item => { if (counts.hasOwnProperty(item.cat)) counts[item.cat]++; });
    jobsData.forEach(deal => { if (counts.hasOwnProperty(deal.cat)) counts[deal.cat]++; });

    const totalCount = directoryData.length + jobsData.length;

    const optionsHtml = [
        `<option value="all">All Categories (${totalCount})</option>`,
        ...Object.keys(CATEGORY_LABELS).map(catKey =>
            `<option value="${catKey}">${CATEGORY_LABELS[catKey]} (${counts[catKey]})</option>`
        )
    ].join('');

    dropCategory.innerHTML = optionsHtml;
    dropCategory.value = previousSelection;
}

function removeResourceElement(id, systemLayer) {
    if (systemLayer === 'directory') {
        directoryData = directoryData.filter(item => item.id !== id);
        saveToStorage('bazaar_directory', directoryData);
    } else {
        localDealsData = localDealsData.filter(item => item.id !== id);
        saveToStorage('bazaar_deals', localDealsData);
    }
    compileMasterState();
}

function isValidUrl(value) {
    try {
        const parsed = new URL(value);
        return parsed.protocol === 'http:' || parsed.protocol === 'https:';
    } catch (e) {
        return false;
    }
}

function setFieldValidity(inputId, isValid) {
    const input = document.getElementById(inputId);
    if (!input) return;
    const group = input.closest('.form-group');
    if (group) group.classList.toggle('invalid', !isValid);
}

document.addEventListener('DOMContentLoaded', () => {
    renderToolDirectoryGrid(directoryData);
    compileMasterState();
    renderStatusBanner('All listings here are added manually by real sellers — nothing is auto-scraped or simulated.');

    const inputSearch = document.getElementById('search-input');
    const dropCategory = document.getElementById('category-filter');

    if (inputSearch) inputSearch.addEventListener('input', executeLiveSearchFiltering);
    if (dropCategory) dropCategory.addEventListener('change', executeLiveSearchFiltering);

    // Form Interceptor: New Seller Listings
    const sellerForm = document.getElementById('sellerForm');
    if (sellerForm) {
        sellerForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const urlValue = document.getElementById('shopUrl').value.trim();
            const urlOk = isValidUrl(urlValue);
            setFieldValidity('shopUrl', urlOk);
            if (!urlOk) return;

            const shopObject = {
                id: Date.now(),
                name: document.getElementById('shopName').value,
                desc: document.getElementById('shopDesc').value,
                cat: document.getElementById('shopCat').value,
                city: document.getElementById('shopCity').value,
                url: urlValue
            };
            directoryData.unshift(shopObject);
            saveToStorage('bazaar_directory', directoryData);
            e.target.reset();
            toggleModal('sellerModal');
            compileMasterState();
        });
    }

    // Form Interceptor: New Deal Posts
    const dealForm = document.getElementById('dealForm');
    if (dealForm) {
        dealForm.addEventListener('submit', (e) => {
            e.preventDefault();
            const urlValue = document.getElementById('dealUrl').value.trim();
            const urlOk = isValidUrl(urlValue);
            setFieldValidity('dealUrl', urlOk);
            if (!urlOk) return;

            const dealObject = {
                id: Date.now(),
                title: document.getElementById('dealTitle').value,
                shop: document.getElementById('dealShop').value,
                cat: document.getElementById('dealCat').value,
                priceNow: document.getElementById('dealPriceNow').value,
                priceWas: document.getElementById('dealPriceWas').value,
                loc: document.getElementById('dealLoc').value,
                url: urlValue
            };
            localDealsData.unshift(dealObject);
            saveToStorage('bazaar_deals', localDealsData);
            e.target.reset();
            toggleModal('dealModal');
            compileMasterState();
        });
    }
});
    </script>
