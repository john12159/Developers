// =========================================================================
// ZAKAT CALCULATOR — pure client-side calculation, no API.
// Rules used (standard across major schools, sourced from Islamic Relief,
// Muslim Aid, and HalalWallet zakat guides):
//   - Nisab (gold standard): value of 87.48g of gold
//   - Nisab (silver standard): value of 612.36g of silver — lower threshold,
//     so more cautious / inclusive of more payers, preferred by many scholars
//   - Zakat rate: 2.5% of total zakatable wealth, once it equals or exceeds
//     the chosen nisab, held for one full lunar year (hawl)
// Since there's no free, real-time, no-key gold/silver price API, the user
// enters today's price per gram themselves — we never fabricate a "live"
// price, since an inaccurate nisab could lead someone to under- or over-pay.
// =========================================================================

const ZAKAT_RATE = 0.025;
const NISAB_GOLD_GRAMS = 87.48;
const NISAB_SILVER_GRAMS = 612.36;

window.initZakat = function initZakat() {
    const root = document.getElementById('zakatRoot');
    if (root.dataset.initialized) return;
    root.dataset.initialized = 'true';
    renderZakatForm();
};

function renderZakatForm() {
    const root = document.getElementById('zakatRoot');
    const saved = loadFromStorage('sakeenah_zakat_inputs', {
        nisabStandard: 'silver',
        goldPricePerGram: '',
        silverPricePerGram: '',
        cash: '', bankSavings: '', investments: '', goldGrams: '', silverGrams: '', businessAssets: '', debtsOwedToYou: '',
        immediateDebts: '', dueExpenses: ''
    });

    root.innerHTML = `
        <div class="panel">
            <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.4rem; font-weight:600;">Nisab Standard</div>
            <div class="radio-row" style="margin-bottom:0.5rem;">
                <label class="radio-pill zakat-standard-pill" data-standard="silver"><input type="radio" name="nisabStandard" value="silver"> Silver (lower, more cautious)</label>
                <label class="radio-pill zakat-standard-pill" data-standard="gold"><input type="radio" name="nisabStandard" value="gold"> Gold (higher threshold)</label>
            </div>
            <div style="font-size:0.75rem; color:var(--text-dim);">Scholars differ on this choice — many recommend the silver standard since it includes more people in the obligation, benefiting more recipients. Consult a scholar if unsure.</div>
        </div>

        <div class="panel">
            <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.75rem; font-weight:600;">Today's Precious Metal Prices</div>
            <div class="form-row">
                <div class="form-group">
                    <label>Gold price (per gram, your currency)</label>
                    <input type="number" min="0" step="0.01" id="goldPricePerGram" placeholder="e.g. 75.00" value="${escapeHtml(saved.goldPricePerGram)}">
                </div>
                <div class="form-group">
                    <label>Silver price (per gram)</label>
                    <input type="number" min="0" step="0.01" id="silverPricePerGram" placeholder="e.g. 0.95" value="${escapeHtml(saved.silverPricePerGram)}">
                </div>
            </div>
            <div style="font-size:0.75rem; color:var(--text-dim);">Prices change daily — check a live source (your local jeweler, bank, or a precious metals site) before calculating.</div>
        </div>

        <div class="panel">
            <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.75rem; font-weight:600;">Zakatable Assets</div>
            <div class="form-group"><label>Cash on hand</label><input type="number" min="0" step="0.01" id="zCash" value="${escapeHtml(saved.cash)}" placeholder="0"></div>
            <div class="form-group"><label>Bank savings / accounts</label><input type="number" min="0" step="0.01" id="zBank" value="${escapeHtml(saved.bankSavings)}" placeholder="0"></div>
            <div class="form-group"><label>Investments / stocks (market value)</label><input type="number" min="0" step="0.01" id="zInvest" value="${escapeHtml(saved.investments)}" placeholder="0"></div>
            <div class="form-row">
                <div class="form-group"><label>Gold owned (grams)</label><input type="number" min="0" step="0.01" id="zGoldG" value="${escapeHtml(saved.goldGrams)}" placeholder="0"></div>
                <div class="form-group"><label>Silver owned (grams)</label><input type="number" min="0" step="0.01" id="zSilverG" value="${escapeHtml(saved.silverGrams)}" placeholder="0"></div>
            </div>
            <div class="form-group"><label>Business assets / trade inventory</label><input type="number" min="0" step="0.01" id="zBusiness" value="${escapeHtml(saved.businessAssets)}" placeholder="0"></div>
            <div class="form-group"><label>Money owed to you (likely to be repaid)</label><input type="number" min="0" step="0.01" id="zReceivable" value="${escapeHtml(saved.debtsOwedToYou)}" placeholder="0"></div>
        </div>

        <div class="panel">
            <div style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.75rem; font-weight:600;">Deductible Liabilities</div>
            <div class="form-group"><label>Debts due within 12 months</label><input type="number" min="0" step="0.01" id="zDebts" value="${escapeHtml(saved.immediateDebts)}" placeholder="0"></div>
            <div class="form-group"><label>Other immediate due expenses</label><input type="number" min="0" step="0.01" id="zExpenses" value="${escapeHtml(saved.dueExpenses)}" placeholder="0"></div>
        </div>

        <button class="btn btn-primary btn-block" id="zakatCalcBtn" style="margin-bottom:1rem;">Calculate Zakat</button>
        <div id="zakatResultArea"></div>
    `;

    // Restore selected standard
    root.querySelectorAll('.zakat-standard-pill').forEach(pill => {
        const checked = pill.dataset.standard === saved.nisabStandard;
        pill.classList.toggle('checked', checked);
        pill.querySelector('input').checked = checked;
        pill.addEventListener('click', () => {
            root.querySelectorAll('.zakat-standard-pill').forEach(p => p.classList.remove('checked'));
            pill.classList.add('checked');
            pill.querySelector('input').checked = true;
        });
    });

    document.getElementById('zakatCalcBtn').addEventListener('click', calculateZakat);
}

function calculateZakat() {
    const num = (id) => Math.max(0, parseFloat(document.getElementById(id).value) || 0);

    const standardPill = document.querySelector('.zakat-standard-pill.checked');
    const nisabStandard = standardPill ? standardPill.dataset.standard : 'silver';

    const goldPrice = num('goldPricePerGram');
    const silverPrice = num('silverPricePerGram');

    const inputs = {
        nisabStandard,
        goldPricePerGram: document.getElementById('goldPricePerGram').value,
        silverPricePerGram: document.getElementById('silverPricePerGram').value,
        cash: document.getElementById('zCash').value,
        bankSavings: document.getElementById('zBank').value,
        investments: document.getElementById('zInvest').value,
        goldGrams: document.getElementById('zGoldG').value,
        silverGrams: document.getElementById('zSilverG').value,
        businessAssets: document.getElementById('zBusiness').value,
        debtsOwedToYou: document.getElementById('zReceivable').value,
        immediateDebts: document.getElementById('zDebts').value,
        dueExpenses: document.getElementById('zExpenses').value
    };
    saveToStorage('sakeenah_zakat_inputs', inputs);

    const resultArea = document.getElementById('zakatResultArea');

    const priceNeeded = nisabStandard === 'gold' ? goldPrice : silverPrice;
    if (priceNeeded <= 0) {
        resultArea.innerHTML = `<div class="status-banner error"><i class="fa-solid fa-triangle-exclamation"></i><span>Please enter the current ${nisabStandard} price per gram to calculate your nisab threshold.</span></div>`;
        return;
    }

    const goldValue = num('zGoldG') * goldPrice;
    const silverValue = num('zSilverG') * silverPrice;

    const totalAssets = num('zCash') + num('zBank') + num('zInvest') + goldValue + silverValue + num('zBusiness') + num('zReceivable');
    const totalLiabilities = num('zDebts') + num('zExpenses');
    const netZakatableWealth = Math.max(0, totalAssets - totalLiabilities);

    const nisabThreshold = nisabStandard === 'gold'
        ? NISAB_GOLD_GRAMS * goldPrice
        : NISAB_SILVER_GRAMS * silverPrice;

    const meetsNisab = netZakatableWealth >= nisabThreshold;
    const zakatDue = meetsNisab ? netZakatableWealth * ZAKAT_RATE : 0;

    resultArea.innerHTML = `
        <div class="panel" style="text-align:center; border-color:${meetsNisab ? 'var(--emerald)' : 'var(--border-color)'};">
            <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.4rem;">Net Zakatable Wealth</div>
            <div style="font-size:1.4rem; font-weight:700; color:#fff; margin-bottom:1rem;">${formatMoney(netZakatableWealth)}</div>

            <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.4rem;">Nisab Threshold (${nisabStandard})</div>
            <div style="font-size:1rem; color:var(--text-main); margin-bottom:1rem;">${formatMoney(nisabThreshold)}</div>

            ${meetsNisab ? `
                <div style="border-top:1px solid var(--border-color); padding-top:1rem;">
                    <div style="font-size:0.8rem; color:var(--text-muted); margin-bottom:0.4rem;">Zakat Due (2.5%)</div>
                    <div style="font-size:2rem; font-weight:800; color:var(--gold-soft);">${formatMoney(zakatDue)}</div>
                </div>
            ` : `
                <div style="border-top:1px solid var(--border-color); padding-top:1rem; color:var(--text-muted); font-size:0.85rem;">
                    Your wealth is below the nisab threshold, so Zakat isn't currently obligatory — unless this wealth has been held above nisab for a full lunar year at some point.
                </div>
            `}
        </div>
        <div class="status-banner" style="margin-top:0;">
            <i class="fa-solid fa-circle-info"></i>
            <span>This is a calculation aid, not a religious ruling. Zakat also requires that wealth be held for one full lunar year (hawl) above nisab. If your situation involves debts, jewelry-for-personal-use, retirement accounts, or business inventory, consider consulting a scholar.</span>
        </div>
    `;
}

function formatMoney(value) {
    return value.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

</script>
</body>
</html>