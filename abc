<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Smart Travel Planner</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',sans-serif;
}

body{
    background:linear-gradient(135deg,#0f172a,#1e293b,#0f172a);
    color:white;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    padding:30px;
}

.container{
    width:100%;
    max-width:1200px;
}

.card{
    background:rgba(255,255,255,0.08);
    backdrop-filter:blur(15px);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:20px;
    padding:30px;
    box-shadow:0 10px 30px rgba(0,0,0,0.4);
}

h1{
    text-align:center;
    margin-bottom:25px;
    color:#38bdf8;
}

.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:15px;
}

.input-group{
    display:flex;
    flex-direction:column;
}

label{
    margin-bottom:8px;
    font-size:14px;
}

input,select{
    padding:12px;
    border:none;
    border-radius:10px;
    background:#1e293b;
    color:white;
}

button{
    margin-top:20px;
    width:100%;
    padding:14px;
    border:none;
    border-radius:12px;
    cursor:pointer;
    font-size:16px;
    font-weight:bold;
    transition:.3s;
}

.generate-btn{
    background:#0ea5e9;
    color:white;
}

.generate-btn:hover{
    background:#0284c7;
}

.download-btn{
    background:#22c55e;
    color:white;
}

.download-btn:hover{
    background:#16a34a;
}

.result{
    margin-top:25px;
}

.day-card{
    background:#1e293b;
    padding:15px;
    margin-bottom:15px;
    border-radius:12px;
    border-left:5px solid #38bdf8;
}

.day-title{
    color:#38bdf8;
    margin-bottom:10px;
}

.loading{
    text-align:center;
    font-size:18px;
    color:#38bdf8;
    margin-top:20px;
}

.footer{
    text-align:center;
    margin-top:20px;
    color:#94a3b8;
}
</style>
</head>

<body>

<div class="container">
<div class="card">

<h1>✈ AI Smart Travel Itinerary Planner</h1>

<div class="grid">

<div class="input-group">
<label>Destination</label>
<input type="text" id="destination" placeholder="e.g. Paris">
</div>

<div class="input-group">
<label>Duration (Days)</label>
<select id="days">
<option>1</option>
<option>2</option>
<option>3</option>
<option>4</option>
<option>5</option>
<option>6</option>
<option>7</option>
</select>
</div>

<div class="input-group">
<label>Budget</label>
<select id="budget">
<option>Budget</option>
<option>Moderate</option>
<option>Luxury</option>
</select>
</div>

<div class="input-group">
<label>Travel Style</label>
<select id="style">
<option>Adventure</option>
<option>Relaxation</option>
<option>Family</option>
<option>Culture</option>
<option>Food</option>
<option>Nature</option>
</select>
</div>

</div>

<button class="generate-btn" onclick="generateItinerary()">
Generate AI Itinerary
</button>

<button class="download-btn" onclick="downloadPlan()">
Download Itinerary
</button>

<div id="loading" class="loading"></div>

<div id="result" class="result"></div>

<div class="footer">
AI-Powered Travel Planner • Single File Web App
</div>

</div>
</div>

<script>

let generatedText = "";

const activities = {
Adventure:[
"Mountain Trekking",
"Zipline Experience",
"ATV Ride",
"Rock Climbing",
"River Rafting",
"Sunset Hiking"
],

Relaxation:[
"Spa Session",
"Beach Walk",
"Luxury Resort Time",
"Yoga Retreat",
"Lake View Relaxation",
"Sunset Cruise"
],

Family:[
"Theme Park Visit",
"Aquarium Tour",
"Zoo Exploration",
"Family Picnic",
"Boat Ride",
"Interactive Museum"
],

Culture:[
"Historic Landmarks",
"Local Museum",
"Art Gallery",
"Heritage Walk",
"Traditional Show",
"Cultural Center Visit"
],

Food:[
"Street Food Tour",
"Fine Dining Experience",
"Local Market Visit",
"Cooking Workshop",
"Cafe Exploration",
"Food Festival Visit"
],

Nature:[
"National Park Visit",
"Waterfall Tour",
"Botanical Garden",
"Wildlife Safari",
"Nature Walk",
"Bird Watching"
]
};

function generateItinerary(){

const destination =
document.getElementById("destination").value;

const days =
parseInt(document.getElementById("days").value);

const budget =
document.getElementById("budget").value;

const style =
document.getElementById("style").value;

if(destination===""){
alert("Please enter destination");
return;
}

document.getElementById("loading").innerHTML =
"🤖 AI is creating your personalized itinerary...";

document.getElementById("result").innerHTML = "";

setTimeout(()=>{

let html="";
generatedText="";

for(let i=1;i<=days;i++){

let act1 =
activities[style][Math.floor(Math.random()*activities[style].length)];

let act2 =
activities[style][Math.floor(Math.random()*activities[style].length)];

let act3 =
activities[style][Math.floor(Math.random()*activities[style].length)];

let budgetText="";

if(budget==="Budget"){
budgetText="Affordable local experiences and public transport";
}
else if(budget==="Moderate"){
budgetText="Comfortable hotels and premium attractions";
}
else{
budgetText="Luxury hotels, private tours and VIP experiences";
}

html+=`
<div class="day-card">
<h3 class="day-title">Day ${i}</h3>
<p><b>Morning:</b> ${act1}</p>
<p><b>Afternoon:</b> ${act2}</p>
<p><b>Evening:</b> ${act3}</p>
<p><b>Budget Strategy:</b> ${budgetText}</p>
</div>
`;

generatedText +=
`Day ${i}\n`+
`Morning: ${act1}\n`+
`Afternoon: ${act2}\n`+
`Evening: ${act3}\n`+
`Budget Strategy: ${budgetText}\n\n`;
}

document.getElementById("loading").innerHTML="";

document.getElementById("result").innerHTML=
`
<h2 style="margin-bottom:15px;color:#38bdf8;">
📍 ${destination} Travel Plan
</h2>
${html}
`;

generatedText =
`AI SMART TRAVEL ITINERARY\n\nDestination: ${destination}\nBudget: ${budget}\nStyle: ${style}\nDuration: ${days} Days\n\n${generatedText}`;

},1500);

}

function downloadPlan(){

if(generatedText===""){
alert("Generate itinerary first");
return;
}

const blob = new Blob(
[generatedText],
{type:"text/plain"}
);

const link = document.createElement("a");

link.href = URL.createObjectURL(blob);

link.download = "Travel_Itinerary.txt";

link.click();

URL.revokeObjectURL(link.href);
}
</script>

</body>
</html>