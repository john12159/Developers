// =========================================================================
// HIJRI CALENDAR — powered by AlAdhan's gToHCalendar endpoint, which maps
// a Gregorian month onto its corresponding Hijri dates. No API key needed.
// Note: this is a date-mapping calendar, not location-dependent the way
// prayer timings are, since the Hijri calendar follows lunar months.
// =========================================================================

window.calendarState = { viewMonth: new Date().getMonth() + 1, viewYear: new Date().getFullYear(), data: null };

window.initCalendar = function initCalendar() {
    const root = document.getElementById('calendarRoot');
    if (root.dataset.initialized) return;
    root.dataset.initialized = 'true';
    fetchHijriCalendarMonth();
};

async function fetchHijriCalendarMonth() {
    const root = document.getElementById('calendarRoot');
    root.innerHTML = `<div class="status-banner"><i class="fa-solid fa-circle-notch fa-spin"></i><span>Loading Hijri calendar…</span></div>`;

    const { viewMonth, viewYear } = window.calendarState;
    try {
        const url = `https://api.aladhan.com/v1/gToHCalendar/${viewMonth}/${viewYear}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (data.code !== 200) throw new Error(data.status || 'API error');

        window.calendarState.data = data.data;
        renderHijriCalendar();
    } catch (e) {
        console.error('Hijri calendar fetch failed:', e);
        root.innerHTML = `<div class="status-banner error"><i class="fa-solid fa-triangle-exclamation"></i><span>Couldn't load the calendar right now (network issue). <button class="btn-inline" onclick="fetchHijriCalendarMonth()">Retry</button></span></div>`;
    }
}

function renderHijriCalendar() {
    const root = document.getElementById('calendarRoot');
    const days = window.calendarState.data;
    if (!days || days.length === 0) return;

    const firstDay = days[0];
    const lastDay = days[days.length - 1];
    const monthLabel = firstDay.gregorian.month.en + ' ' + firstDay.gregorian.year;
    const hijriSpan = firstDay.hijri.month.en === lastDay.hijri.month.en
        ? `${firstDay.hijri.month.en} ${firstDay.hijri.year} AH`
        : `${firstDay.hijri.month.en} – ${lastDay.hijri.month.en} ${lastDay.hijri.year} AH`;

    const todayStr = new Date().toDateString();

    root.innerHTML = `
        <div class="panel" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
            <button class="btn-outline-sm" onclick="changeCalendarMonth(-1)"><i class="fa-solid fa-chevron-left"></i></button>
            <div style="text-align:center;">
                <div style="font-weight:700; color:#fff;">${escapeHtml(monthLabel)}</div>
                <div style="font-size:0.78rem; color:var(--gold-soft);">${escapeHtml(hijriSpan)}</div>
            </div>
            <button class="btn-outline-sm" onclick="changeCalendarMonth(1)"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
        <div class="panel" style="padding:0.75rem;">
            <div style="display:grid; grid-template-columns:repeat(7, 1fr); gap:0.3rem; font-size:0.7rem; color:var(--text-dim); text-align:center; margin-bottom:0.4rem;">
                ${['S','M','T','W','T','F','S'].map(d => `<div>${d}</div>`).join('')}
            </div>
            <div style="display:grid; grid-template-columns:repeat(7, 1fr); gap:0.3rem;">
                ${renderCalendarCells(days)}
            </div>
        </div>
    `;

    function isToday(dayObj) {
        const d = new Date(`${dayObj.gregorian.year}-${dayObj.gregorian.month.number}-${dayObj.gregorian.day}`);
        return d.toDateString() === todayStr;
    }

    function renderCalendarCells(daysArr) {
        const firstWeekday = new Date(`${daysArr[0].gregorian.year}-${daysArr[0].gregorian.month.number}-${daysArr[0].gregorian.day}`).getDay();
        const blanks = Array(firstWeekday).fill('<div></div>').join('');
        const cells = daysArr.map(d => {
            const today = isToday(d);
            return `<div style="
                text-align:center; padding:0.4rem 0.1rem; border-radius:0.4rem;
                background:${today ? 'var(--emerald)' : 'transparent'};
            ">
                <div style="font-size:0.85rem; font-weight:${today ? '700' : '500'}; color:${today ? '#fff' : 'var(--text-main)'};">${d.gregorian.day}</div>
                <div style="font-size:0.62rem; color:${today ? 'rgba(255,255,255,0.85)' : 'var(--text-dim)'};">${d.hijri.day}</div>
            </div>`;
        }).join('');
        return blanks + cells;
    }
}

window.changeCalendarMonth = function changeCalendarMonth(delta) {
    let { viewMonth, viewYear } = window.calendarState;
    viewMonth += delta;
    if (viewMonth > 12) { viewMonth = 1; viewYear++; }
    if (viewMonth < 1) { viewMonth = 12; viewYear--; }
    window.calendarState.viewMonth = viewMonth;
    window.calendarState.viewYear = viewYear;
    fetchHijriCalendarMonth();
};

