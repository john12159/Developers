<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sakeenah — Prayer Times & Companion</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<style>
:root {
    --bg-primary: #0a1612;
    --bg-surface: #0f2119;
    --bg-surface-hover: #15301f;
    --bg-elevated: #122a1e;
    --text-main: #f0f7f2;
    --text-muted: #8fa89a;
    --text-dim: #5f7d6c;
    --gold: #d4af37;
    --gold-soft: #e8c863;
    --emerald: #1f8a5f;
    --emerald-bright: #2bb074;
    --border-color: #1b3326;
    --danger: #e07856;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
    font-family: 'Outfit', ui-sans-serif, system-ui, sans-serif;
    background: radial-gradient(ellipse at top, #0d1f16, var(--bg-primary) 60%);
    color: var(--text-main);
    line-height: 1.5;
    min-height: 100vh;
    padding-bottom: 5.5rem;
}
.arabic { font-family: 'Amiri', serif; }

/* Top bar */
.topbar {
    background: rgba(15, 33, 25, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 0.9rem 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.brand { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; font-size: 1.05rem; color: #fff; }
.brand i { color: var(--gold); }
.location-chip {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--bg-elevated); border: 1px solid var(--border-color);
    padding: 0.4rem 0.75rem; border-radius: 9999px; font-size: 0.78rem; color: var(--text-muted);
    cursor: pointer; transition: border-color 0.15s;
}
.location-chip:hover { border-color: var(--emerald); color: var(--text-main); }
.location-chip i { color: var(--emerald-bright); }
.settings-btn {
    background: var(--bg-elevated); border: 1px solid var(--border-color); color: var(--text-muted);
    width: 36px; height: 36px; border-radius: 9999px; cursor: pointer; font-size: 0.95rem;
    display: flex; align-items: center; justify-content: center; transition: all 0.15s;
}
.settings-btn:hover { color: #fff; border-color: var(--emerald); }

/* Main container */
.app-container { max-width: 720px; margin: 0 auto; padding: 1.25rem; }

/* Status banners */
.status-banner {
    display: flex; align-items: center; gap: 0.6rem; background: var(--bg-elevated);
    border: 1px solid var(--border-color); border-radius: 0.6rem; padding: 0.8rem 1rem;
    margin-bottom: 1rem; font-size: 0.82rem; color: var(--text-muted);
}
.status-banner.error { border-color: rgba(224, 120, 86, 0.4); color: #f3b59b; }
.status-banner i { color: var(--gold); flex-shrink: 0; }
.status-banner.error i { color: var(--danger); }
.status-banner button.btn-inline {
    background: var(--emerald); color: #fff; border: none; padding: 0.4rem 0.8rem;
    border-radius: 0.4rem; font-size: 0.78rem; cursor: pointer; font-weight: 600; flex-shrink: 0; margin-left: auto;
}

/* Hero next-prayer card */
.next-prayer-card {
    background: linear-gradient(135deg, var(--bg-elevated), var(--bg-surface));
    border: 1px solid var(--border-color);
    border-radius: 1.1rem;
    padding: 1.75rem;
    text-align: center;
    margin-bottom: 1.5rem;
    position: relative;
    overflow: hidden;
}
.next-prayer-card::before {
    content: '';
    position: absolute; top: -50%; right: -20%; width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(212,175,55,0.08), transparent 70%);
    pointer-events: none;
}
.np-label { font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.4rem; }
.np-name { font-size: 2rem; font-weight: 800; color: #fff; margin-bottom: 0.25rem; }
.np-time { font-size: 1.1rem; color: var(--gold-soft); font-weight: 600; margin-bottom: 0.75rem; }
.np-countdown { font-size: 0.95rem; color: var(--text-muted); font-variant-numeric: tabular-nums; }
.np-countdown strong { color: var(--emerald-bright); font-weight: 700; }
.hijri-date-line { font-size: 0.8rem; color: var(--text-dim); margin-top: 0.9rem; padding-top: 0.9rem; border-top: 1px solid var(--border-color); }

/* Today's timings grid */
.timings-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(95px, 1fr)); gap: 0.6rem;
    margin-bottom: 1.5rem;
}
.timing-cell {
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.7rem;
    padding: 0.85rem 0.5rem; text-align: center; transition: all 0.15s;
}
.timing-cell.is-next { border-color: var(--emerald); background: var(--bg-surface-hover); }
.timing-cell .t-name { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 0.35rem; }
.timing-cell .t-time { font-size: 1.05rem; font-weight: 700; color: var(--text-main); font-variant-numeric: tabular-nums; }
.timing-cell.is-next .t-time { color: var(--gold-soft); }

/* Suhoor/Iftar card */
.fast-card {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1px;
    background: var(--border-color); border-radius: 0.9rem; overflow: hidden;
    margin-bottom: 1.5rem; border: 1px solid var(--border-color);
}
.fast-cell { background: var(--bg-surface); padding: 1.1rem; text-align: center; }
.fast-cell .f-label { font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem; }
.fast-cell .f-time { font-size: 1.3rem; font-weight: 700; color: var(--text-main); }
.fast-cell .f-sub { font-size: 0.72rem; color: var(--text-dim); margin-top: 0.2rem; }
.fast-cell.suhoor .f-time { color: #93c5fd; }
.fast-cell.iftar .f-time { color: var(--gold-soft); }

/* Section nav (bottom tabs) */
.bottom-nav {
    position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
    background: rgba(15, 33, 25, 0.92); backdrop-filter: blur(10px);
    border-top: 1px solid var(--border-color);
    display: flex; justify-content: space-around; padding: 0.5rem 0.25rem;
}
.nav-item {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    background: none; border: none; color: var(--text-dim); font-size: 0.65rem; cursor: pointer;
    padding: 0.3rem 0.5rem; border-radius: 0.5rem; flex: 1; max-width: 80px; font-weight: 500;
}
.nav-item i { font-size: 1.15rem; }
.nav-item.active { color: var(--gold-soft); }

/* Section views */
.section-view { display: none; }
.section-view.active { display: block; }
.section-title { font-size: 1.3rem; font-weight: 700; color: #fff; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }
.section-title i { color: var(--gold); }

/* Generic cards / buttons */
.panel { background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 0.9rem; padding: 1.25rem; margin-bottom: 1rem; }
.btn {
    padding: 0.65rem 1.25rem; border-radius: 0.5rem; font-weight: 600; cursor: pointer;
    font-size: 0.875rem; border: 1px solid transparent; transition: all 0.15s ease;
}
.btn-primary { background: var(--emerald); color: #fff; }
.btn-primary:hover { background: var(--emerald-bright); }
.btn-secondary { background: var(--bg-elevated); color: var(--text-main); border-color: var(--border-color); }
.btn-secondary:hover { background: var(--bg-surface-hover); }
.btn-block { width: 100%; display: block; }
.btn-outline-sm { background: transparent; border-color: var(--border-color); color: var(--text-muted); padding: 0.35rem 0.7rem; font-size: 0.78rem; border-radius: 0.4rem; cursor: pointer; }
.btn-outline-sm:hover { color: #fff; border-color: var(--emerald); }

/* Modals */
.modal-overlay {
    position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(5,12,9,0.8);
    backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center;
    z-index: 1000; padding: 1rem;
}
.modal-overlay.active { display: flex; }
.modal-box {
    background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 1rem;
    width: 100%; max-width: 460px; padding: 1.5rem; max-height: 88vh; overflow-y: auto;
    animation: modalSlide 0.2s cubic-bezier(0.16,1,0.3,1);
}
@keyframes modalSlide { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
.modal-header h3 { font-size: 1.1rem; font-weight: 700; }
.close-btn { background: none; border: none; color: var(--text-muted); font-size: 1.4rem; cursor: pointer; line-height: 1; }
.close-btn:hover { color: #fff; }

.form-group { margin-bottom: 1.1rem; }
.form-group label { display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.35rem; font-weight: 500; }
.form-group input, .form-group select {
    width: 100%; background: var(--bg-primary); border: 1px solid var(--border-color);
    padding: 0.6rem 0.7rem; border-radius: 0.45rem; color: white; outline: none; font-size: 0.9rem;
}
.form-group input:focus, .form-group select:focus { border-color: var(--emerald); }
.form-group select option { background: var(--bg-surface); }
.radio-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.radio-pill {
    background: var(--bg-elevated); border: 1px solid var(--border-color); border-radius: 9999px;
    padding: 0.4rem 0.9rem; font-size: 0.8rem; cursor: pointer; color: var(--text-muted);
}
.radio-pill input { display: none; }
.radio-pill.checked { background: var(--emerald); color: #fff; border-color: var(--emerald); }

@media(max-width: 480px) {
    .np-name { font-size: 1.6rem; }
    .timings-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
<body>

<!-- Top Bar -->
<header class="topbar">
    <div class="brand"><i class="fa-solid fa-moon"></i> Sakeenah</div>
    <div style="display:flex; align-items:center; gap:0.6rem;">
        <button class="location-chip" id="locationChip" onclick="toggleModal('locationModal')">
            <i class="fa-solid fa-location-dot"></i> <span id="locationLabel">Locating…</span>
        </button>
        <button class="settings-btn" onclick="toggleModal('settingsModal')"><i class="fa-solid fa-gear"></i></button>
    </div>
</header>

<div class="app-container">
    <div id="globalStatusArea"></div>

    <!-- HOME / PRAYER TIMES -->
    <section id="view-home" class="section-view active">

        <div class="next-prayer-card">
            <div class="np-label">Next Prayer</div>
            <div class="np-name" id="nextPrayerName">—</div>
            <div class="np-time" id="nextPrayerTime">—:—</div>
            <div class="np-countdown">in <strong id="nextPrayerCountdown">—</strong></div>
            <div class="hijri-date-line" id="hijriDateLine">Loading Hijri date…</div>
        </div>

        <div class="timings-grid" id="timingsGrid">
            <!-- populated by JS -->
        </div>

        <div class="fast-card">
            <div class="fast-cell suhoor">
                <div class="f-label"><i class="fa-solid fa-cloud-moon"></i> Suhoor ends</div>
                <div class="f-time" id="suhoorTime">—:—</div>
                <div class="f-sub">at Fajr (Imsak)</div>
            </div>
            <div class="fast-cell iftar">
                <div class="f-label"><i class="fa-solid fa-sun"></i> Iftar begins</div>
                <div class="f-time" id="iftarTime">—:—</div>
                <div class="f-sub">at Maghrib</div>
            </div>
        </div>
    </section>

    <!-- TASBIH -->
    <section id="view-tasbih" class="section-view">
        <div class="section-title"><i class="fa-solid fa-circle-dot"></i> Tasbih Counter</div>
        <div id="tasbihRoot"></div>
    </section>

    <!-- HIJRI CALENDAR -->
    <section id="view-calendar" class="section-view">
        <div class="section-title"><i class="fa-solid fa-calendar-days"></i> Hijri Calendar</div>
        <div id="calendarRoot"></div>
    </section>

    <!-- QURAN -->
    <section id="view-quran" class="section-view">
        <div class="section-title"><i class="fa-solid fa-book-quran"></i> Quran</div>
        <div id="quranRoot"></div>
    </section>

    <!-- ZAKAT -->
    <section id="view-zakat" class="section-view">
        <div class="section-title"><i class="fa-solid fa-hand-holding-dollar"></i> Zakat Calculator</div>
        <div id="zakatRoot"></div>
    </section>
</div>

<!-- Bottom Navigation -->
<nav class="bottom-nav">
    <button class="nav-item active" data-view="home" onclick="switchSection('home')"><i class="fa-solid fa-mosque"></i>Times</button>
    <button class="nav-item" data-view="tasbih" onclick="switchSection('tasbih')"><i class="fa-solid fa-circle-dot"></i>Tasbih</button>
    <button class="nav-item" data-view="calendar" onclick="switchSection('calendar')"><i class="fa-solid fa-calendar-days"></i>Hijri</button>
    <button class="nav-item" data-view="quran" onclick="switchSection('quran')"><i class="fa-solid fa-book-quran"></i>Quran</button>
    <button class="nav-item" data-view="zakat" onclick="switchSection('zakat')"><i class="fa-solid fa-hand-holding-dollar"></i>Zakat</button>
</nav>

<!-- LOCATION MODAL -->
<div class="modal-overlay" id="locationModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Set Location</h3>
            <button class="close-btn" onclick="toggleModal('locationModal')">&times;</button>
        </div>
        <button class="btn btn-primary btn-block" onclick="requestGeolocation()" style="margin-bottom:1rem;">
            <i class="fa-solid fa-location-crosshairs"></i> Use My Current Location
        </button>
        <div style="text-align:center; color:var(--text-dim); font-size:0.8rem; margin-bottom:1rem;">or search manually</div>
        <div class="form-group">
            <label>City name</label>
            <input type="text" id="manualCityInput" placeholder="e.g. Karachi, Pakistan">
        </div>
        <button class="btn btn-secondary btn-block" onclick="searchManualCity()">Search</button>
        <div id="locationModalStatus" style="margin-top:0.75rem; font-size:0.8rem; color:var(--text-muted);"></div>
    </div>
</div>

<!-- SETTINGS MODAL -->
<div class="modal-overlay" id="settingsModal">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Settings</h3>
            <button class="close-btn" onclick="toggleModal('settingsModal')">&times;</button>
        </div>
        <div class="form-group">
            <label>Calculation Method</label>
            <select id="methodSelect">
                <option value="3">Muslim World League</option>
                <option value="2">ISNA (North America)</option>
                <option value="4">Umm Al-Qura, Makkah</option>
                <option value="5">Egyptian General Authority</option>
                <option value="1">University of Islamic Sciences, Karachi</option>
                <option value="8">Gulf Region</option>
                <option value="9">Kuwait</option>
                <option value="10">Qatar</option>
                <option value="11">Singapore</option>
                <option value="17">JAKIM, Malaysia</option>
                <option value="20">Kemenag, Indonesia</option>
                <option value="7">Tehran</option>
                <option value="0">Jafari (Shia Ithna-Ashari)</option>
            </select>
        </div>
        <div class="form-group">
            <label>Asr Calculation (Madhab)</label>
            <div class="radio-row">
                <label class="radio-pill" data-school="0"><input type="radio" name="school" value="0"> Shafi/Maliki/Hanbali</label>
                <label class="radio-pill" data-school="1"><input type="radio" name="school" value="1"> Hanafi</label>
            </div>
        </div>
        <button class="btn btn-primary btn-block" onclick="saveSettingsAndRefresh()">Save & Refresh Timings</button>
    </div>
</div>

<script>
window.appState = {
    latitude: null,
    longitude: null,
    locationLabel: 'Locating…',
    method: 3,
    school: 0,
    todayTimings: null,
    hijriToday: null,
    nextPrayerKey: null,
    nextPrayerTimestamp: null
};

function toggleModal(modalId) {
    const m = document.getElementById(modalId);
    if (m) m.classList.toggle('active');
}

function switchSection(viewName) {
    document.querySelectorAll('.section-view').forEach(v => v.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById(`view-${viewName}`).classList.add('active');
    document.querySelector(`.nav-item[data-view="${viewName}"]`).classList.add('active');

    // Lazy-init each section the first time it's opened
    if (viewName === 'tasbih' && window.initTasbih) window.initTasbih();
    if (viewName === 'calendar' && window.initCalendar) window.initCalendar();
    if (viewName === 'quran' && window.initQuran) window.initQuran();
    if (viewName === 'zakat' && window.initZakat) window.initZakat();
}

function renderGlobalStatus(message, isError) {
    const area = document.getElementById('globalStatusArea');
    if (!area) return;
    if (!message) { area.innerHTML = ''; return; }
    area.innerHTML = `<div class="status-banner ${isError ? 'error' : ''}">
        <i class="fa-solid ${isError ? 'fa-triangle-exclamation' : 'fa-circle-info'}"></i>
        <span>${message}</span>
        ${isError ? `<button class="btn-inline" onclick="toggleModal('locationModal')">Set Location</button>` : ''}
    </div>`;
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
}

// =========================================================================
// PRAYER TIMES ENGINE — powered by the free AlAdhan API (api.aladhan.com)
// No API key required. Method IDs match AlAdhan's official /v1/methods list.
// =========================================================================

const PRAYER_ORDER = ['Fajr', 'Sunrise', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'];
const PRAYER_LABELS = { Fajr: 'Fajr', Sunrise: 'Sunrise', Dhuhr: 'Dhuhr', Asr: 'Asr', Maghrib: 'Maghrib', Isha: 'Isha' };
// Prayers used for the "next prayer" countdown (Sunrise isn't a prayer, so excluded there)
const COUNTDOWN_PRAYERS = ['Fajr', 'Dhuhr', 'Asr', 'Maghrib', 'Isha'];

function loadFromStorage(key, fallback) {
    try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
    } catch (e) {
        console.warn(`Could not read ${key}`, e);
        return fallback;
    }
}
function saveToStorage(key, value) {
    try { localStorage.setItem(key, JSON.stringify(value)); }
    catch (e) { console.warn(`Could not persist ${key}`, e); }
}

function initSettingsFromStorage() {
    const saved = loadFromStorage('sakeenah_settings', null);
    if (saved) {
        window.appState.method = saved.method;
        window.appState.school = saved.school;
    }
    document.getElementById('methodSelect').value = String(window.appState.method);
    document.querySelectorAll('.radio-pill').forEach(pill => {
        const isChecked = Number(pill.dataset.school) === window.appState.school;
        pill.classList.toggle('checked', isChecked);
        pill.querySelector('input').checked = isChecked;
    });
    document.querySelectorAll('.radio-pill').forEach(pill => {
        pill.addEventListener('click', () => {
            document.querySelectorAll('.radio-pill').forEach(p => p.classList.remove('checked'));
            pill.classList.add('checked');
            pill.querySelector('input').checked = true;
        });
    });
}

function saveSettingsAndRefresh() {
    const method = Number(document.getElementById('methodSelect').value);
    const checkedPill = document.querySelector('.radio-pill.checked');
    const school = checkedPill ? Number(checkedPill.dataset.school) : 0;
    window.appState.method = method;
    window.appState.school = school;
    saveToStorage('sakeenah_settings', { method, school });
    toggleModal('settingsModal');
    if (window.appState.latitude != null) {
        fetchPrayerTimings();
    }
}

function requestGeolocation(isAutoRequest) {
    const statusEl = document.getElementById('locationModalStatus');

    if (!navigator.geolocation) {
        if (statusEl) statusEl.textContent = 'Geolocation is not supported in this browser. Please search your city manually.';
        if (isAutoRequest) toggleModal('locationModal');
        return;
    }
    if (statusEl) statusEl.textContent = 'Requesting location permission…';

    navigator.geolocation.getCurrentPosition(
        (pos) => {
            window.appState.latitude = pos.coords.latitude;
            window.appState.longitude = pos.coords.longitude;
            window.appState.locationLabel = `${pos.coords.latitude.toFixed(2)}°, ${pos.coords.longitude.toFixed(2)}°`;
            document.getElementById('locationLabel').textContent = window.appState.locationLabel;
            saveToStorage('sakeenah_location', { latitude: pos.coords.latitude, longitude: pos.coords.longitude, label: window.appState.locationLabel });
            // Only close the modal if it was opened (manual trigger) — on
            // auto-request at first load, the modal was never opened.
            if (!isAutoRequest) toggleModal('locationModal');
            fetchPrayerTimings();
            reverseGeocodeLabel(pos.coords.latitude, pos.coords.longitude);
        },
        (err) => {
            console.warn('Geolocation error:', err);
            const message = 'Location permission denied or unavailable. Please search your city manually below.';
            if (statusEl) statusEl.textContent = message;
            document.getElementById('locationLabel').textContent = 'Set location';
            renderGlobalStatus('We couldn\'t access your location automatically. Please set it manually to see accurate prayer times.', true);
            if (isAutoRequest) toggleModal('locationModal');
        },
        { enableHighAccuracy: false, timeout: 10000, maximumAge: 600000 }
    );
}

/**
 * Resolves coordinates to a human-readable place name using AlAdhan's
 * geocoding-backed address endpoint, purely for display in the location
 * chip. Failure here doesn't affect prayer time accuracy — it's cosmetic.
 */
async function reverseGeocodeLabel(lat, lon) {
    try {
        const res = await fetch(`https://api.aladhan.com/v1/timings?latitude=${lat}&longitude=${lon}&method=${window.appState.method}`);
        const data = await res.json();
        if (data?.data?.meta?.timezone) {
            const tz = data.data.meta.timezone.split('/').pop().replace(/_/g, ' ');
            window.appState.locationLabel = tz;
            document.getElementById('locationLabel').textContent = tz;
        }
    } catch (e) {
        // Non-critical — keep showing coordinates
    }
}

/**
 * Manual city search using AlAdhan's timingsByAddress endpoint, which
 * geocodes the address server-side. We immediately request today's timings
 * for that address, then extract the resolved lat/long from the response
 * meta so subsequent days can be fetched directly by coordinates.
 */
async function searchManualCity() {
    const cityValue = document.getElementById('manualCityInput').value.trim();
    if (!cityValue) return;

    const statusEl = document.getElementById('locationModalStatus');
    statusEl.textContent = 'Searching…';

    try {
        const url = `https://api.aladhan.com/v1/timingsByAddress?address=${encodeURIComponent(cityValue)}&method=${window.appState.method}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (data.code !== 200) throw new Error(data.status || 'Lookup failed');

        const meta = data.data.meta;
        window.appState.latitude = meta.latitude;
        window.appState.longitude = meta.longitude;
        window.appState.locationLabel = cityValue;
        document.getElementById('locationLabel').textContent = cityValue;
        saveToStorage('sakeenah_location', { latitude: meta.latitude, longitude: meta.longitude, label: cityValue });

        applyTimingsResponse(data.data);
        toggleModal('locationModal');
        renderGlobalStatus('', false);
    } catch (e) {
        console.error('Manual city search failed:', e);
        statusEl.textContent = "Couldn't find that location. Try a more specific name, e.g. 'Lahore, Pakistan'.";
    }
}

/**
 * Core fetch: gets today's timings for the current stored coordinates.
 */
async function fetchPrayerTimings() {
    if (window.appState.latitude == null || window.appState.longitude == null) return;

    renderGlobalStatus('Fetching today\'s prayer timings…', false);

    try {
        const timestamp = Math.floor(Date.now() / 1000);
        const url = `https://api.aladhan.com/v1/timings/${timestamp}?latitude=${window.appState.latitude}&longitude=${window.appState.longitude}&method=${window.appState.method}&school=${window.appState.school}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (data.code !== 200) throw new Error(data.status || 'API error');

        applyTimingsResponse(data.data);
        renderGlobalStatus('', false);
    } catch (e) {
        console.error('Prayer timings fetch failed:', e);
        renderGlobalStatus("Couldn't reach the prayer times service right now (network issue). Showing last known timings if available.", true);
    }
}

function applyTimingsResponse(data) {
    window.appState.todayTimings = data.timings;
    window.appState.hijriToday = data.date.hijri;
    saveToStorage('sakeenah_last_timings', { timings: data.timings, hijri: data.date.hijri, gregorian: data.date.gregorian, fetchedAt: Date.now() });
    renderTimingsGrid();
    renderHijriLine();
    renderFastCard();
    updateNextPrayer();
}

function renderTimingsGrid() {
    const grid = document.getElementById('timingsGrid');
    const t = window.appState.todayTimings;
    if (!grid || !t) return;

    grid.innerHTML = PRAYER_ORDER.map(key => {
        const isNext = key === window.appState.nextPrayerKey;
        const timeClean = (t[key] || '--:--').split(' ')[0];
        return `<div class="timing-cell ${isNext ? 'is-next' : ''}">
            <div class="t-name">${PRAYER_LABELS[key]}</div>
            <div class="t-time">${escapeHtml(timeClean)}</div>
        </div>`;
    }).join('');
}

function renderHijriLine() {
    const el = document.getElementById('hijriDateLine');
    const h = window.appState.hijriToday;
    if (!el || !h) return;
    el.textContent = `${h.day} ${h.month.en} ${h.year} AH`;
}

function renderFastCard() {
    const t = window.appState.todayTimings;
    if (!t) return;
    document.getElementById('suhoorTime').textContent = (t.Imsak || t.Fajr || '--:--').split(' ')[0];
    document.getElementById('iftarTime').textContent = (t.Maghrib || '--:--').split(' ')[0];
}

/**
 * Parses a "HH:MM" (24h) time string against today's date in the browser's
 * local time. AlAdhan returns times already adjusted for the location's
 * timezone, so we treat them as wall-clock times for "now".
 */
function timeStringToTodayDate(timeStr) {
    const clean = (timeStr || '').split(' ')[0];
    const [h, m] = clean.split(':').map(Number);
    if (Number.isNaN(h) || Number.isNaN(m)) return null;
    const d = new Date();
    d.setHours(h, m, 0, 0);
    return d;
}

function updateNextPrayer() {
    const t = window.appState.todayTimings;
    if (!t) return;

    const now = new Date();
    let nextKey = null;
    let nextDate = null;

    for (const key of COUNTDOWN_PRAYERS) {
        const candidate = timeStringToTodayDate(t[key]);
        if (candidate && candidate > now) {
            nextKey = key;
            nextDate = candidate;
            break;
        }
    }

    // All of today's prayers have passed — next is tomorrow's Fajr.
    // We show today's Fajr time as a placeholder estimate and re-fetch at midnight.
    if (!nextKey) {
        nextKey = 'Fajr';
        const tomorrowFajr = timeStringToTodayDate(t.Fajr);
        if (tomorrowFajr) tomorrowFajr.setDate(tomorrowFajr.getDate() + 1);
        nextDate = tomorrowFajr;
    }

    window.appState.nextPrayerKey = nextKey;
    window.appState.nextPrayerTimestamp = nextDate ? nextDate.getTime() : null;

    document.getElementById('nextPrayerName').textContent = PRAYER_LABELS[nextKey];
    document.getElementById('nextPrayerTime').textContent = (t[nextKey] || '--:--').split(' ')[0];
    renderTimingsGrid();
    tickCountdown();
}

function tickCountdown() {
    const target = window.appState.nextPrayerTimestamp;
    const el = document.getElementById('nextPrayerCountdown');
    if (!target || !el) return;

    const diffMs = target - Date.now();
    if (diffMs <= 0) {
        // Time to refresh — the prayer has arrived.
        fetchPrayerTimings();
        return;
    }
    const totalMinutes = Math.floor(diffMs / 60000);
    const hours = Math.floor(totalMinutes / 60);
    const minutes = totalMinutes % 60;
    el.innerHTML = hours > 0
        ? `${hours}h ${minutes}m`
        : `${minutes}m`;
}

setInterval(tickCountdown, 30000);

