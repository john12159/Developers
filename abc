// ===================== TREES =====================
function makeTree(x, bottom, scale) {
  const tree = document.createElement('div');
  tree.className = 'tree';
  const tw = 80 * scale, th = 130 * scale;
  const trunkW = 12 * scale, trunkH = 35 * scale;
  const greenShades = ['#15803d','#16a34a','#166534','#22c55e','#14532d'];
  const fc = greenShades[Math.floor(Math.random() * greenShades.length)];
  tree.style.cssText = `left:${x}%;bottom:${bottom}%;width:${tw}px;height:${th}px;`;
  // Decide tree type
  const type = Math.random();
  if (type < 0.4) {
    // Pine
    tree.innerHTML = `
      <div class="tree-trunk" style="width:${trunkW}px;height:${trunkH}px;"></div>
      <div class="tree-foliage" style="--fc:${fc};border-left-width:${tw*0.35}px;border-right-width:${tw*0.35}px;border-bottom-width:${th*0.45}px;bottom:${trunkH*0.7}px;"></div>
      <div class="tree-foliage" style="--fc:${fc};border-left-width:${tw*0.28}px;border-right-width:${tw*0.28}px;border-bottom-width:${th*0.38}px;bottom:${trunkH+th*0.18}px;"></div>
      <div class="tree-foliage" style="--fc:${fc};border-left-width:${tw*0.2}px;border-right-width:${tw*0.2}px;border-bottom-width:${th*0.28}px;bottom:${trunkH+th*0.35}px;animation-delay:0.5s;"></div>`;
  } else if (type < 0.7) {
    // Oak
    const leafSize = tw * 0.95;
    tree.innerHTML = `
      <div class="tree-trunk" style="width:${trunkW}px;height:${trunkH*1.3}px;"></div>
      <div class="oak-leaves" style="width:${leafSize}px;height:${leafSize*0.85}px;bottom:${trunkH*1.0}px;left:${(tw-leafSize)/2}px;background:radial-gradient(circle at 40% 40%,${fc},${fc}cc);"></div>
      <div class="oak-leaves" style="width:${leafSize*0.65}px;height:${leafSize*0.65}px;bottom:${trunkH*1.2}px;left:${tw*0.4}px;background:radial-gradient(circle,${fc}dd,${fc});animation-delay:0.3s;"></div>
      <div class="oak-leaves" style="width:${leafSize*0.6}px;height:${leafSize*0.6}px;bottom:${trunkH*1.1}px;left:${-tw*0.05}px;background:radial-gradient(circle,${fc}cc,${fc}aa);animation-delay:0.6s;"></div>`;
  } else {
    // Tropical / palm-like
    tree.innerHTML = `
      <div class="tree-trunk" style="width:${trunkW*0.8}px;height:${trunkH*1.6}px;background:linear-gradient(180deg,#a16207,#78350f);border-radius:6px;transform:translateX(-50%) rotate(5deg);"></div>
      <div class="oak-leaves" style="width:${tw*0.9}px;height:${th*0.35}px;bottom:${trunkH*1.4}px;left:0;background:radial-gradient(ellipse,${fc},${fc}99);border-radius:50%;animation-delay:0.2s;"></div>
      <div class="oak-leaves" style="width:${tw*0.75}px;height:${th*0.28}px;bottom:${trunkH*1.55}px;left:${tw*0.1}px;background:radial-gradient(ellipse,${fc}cc,${fc}88);border-radius:50%;animation-delay:0.5s;"></div>`;
  }
  return tree;
}

