  ff.className = 'firefly';
  const fx = (Math.random()-0.5)*80, fy = (Math.random()-0.5)*60;
  ff.style.cssText = `left:${Math.random()*100}%;bottom:${15+Math.random()*40}%;--fd:${3+Math.random()*5}s;--fx:${fx}px;--fy:${fy}px;animation-delay:${Math.random()*6}s;`;
  firefliesEl.appendChild(ff);
}

// ===================== FALLING PETALS / LEAVES =====================
const particlesEl = document.getElementById('particles');
const petalColors = ['#fca5a5','#fcd34d','#f9a8d4','#a5f3fc','#bbf7d0','#c4b5fd','#fed7aa'];
function spawnPetal() {
  const p = document.createElement('div');
  p.className = 'particle';
  const size = 6 + Math.random() * 10;
  const dur = 5 + Math.random() * 8;
  const col = petalColors[Math.floor(Math.random() * petalColors.length)];
  p.style.cssText = `width:${size}px;height:${size}px;background:${col};left:${Math.random()*100}%;top:-10px;animation-duration:${dur}s;animation-delay:${Math.random()*3}s;border-radius:${Math.random()>0.5?'50%':'3px'};opacity:0.7;`;
  particlesEl.appendChild(p);
  setTimeout(() => p.remove(), (dur + 3) * 1000);
}
setInterval(spawnPetal, 400);

// ===================== CLICK EFFECTS =====================
document.addEventListener('click', e => {
  for (let i = 0; i < 12; i++) {
    const spark = document.createElement('div');
    const angle = (i / 12) * Math.PI * 2;
    const speed = 3 + Math.random() * 5;
    const colors = ['#fbbf24','#f97316','#ec4899','#a78bfa','#34d399'];
    const size = 5 + Math.random() * 8;
    spark.style.cssText = `position:fixed;width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random()*5)]};border-radius:50%;left:${e.clientX}px;top:${e.clientY}px;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);`;
    document.body.appendChild(spark);
    let vx = Math.cos(angle)*speed, vy = Math.sin(angle)*speed, opacity = 1;
    const go = () => {
      vy += 0.15; vx *= 0.97;
      const nx = parseFloat(spark.style.left)+vx, ny = parseFloat(spark.style.top)+vy;
      opacity -= 0.025;
      spark.style.left = nx+'px'; spark.style.top = ny+'px'; spark.style.opacity = opacity;
      if (opacity > 0) requestAnimationFrame(go); else spark.remove();
    };
    requestAnimationFrame(go);
  }
});

// ===================== DAY/NIGHT CYCLE =====================
let timeOfDay = 0;
setInterval(() => {
  timeOfDay = (timeOfDay + 1) % 360;
  const t = timeOfDay / 360;
  // Subtly shift the sky color
  document.querySelector('.sky').style.filter = `hue-rotate(${Math.sin(t*Math.PI*2)*15}deg) brightness(${0.9+Math.sin(t*Math.PI)*0.2})`;
}, 200);

console.log('%c✨ Living World Loaded! Click anywhere for magic! ✨', 'color:#fbbf24;font-size:16px;font-weight:bold;');
</script>
