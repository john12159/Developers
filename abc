<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sign in with Tasbih Account</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg-deep: #0D3B2E;
    --bg-deep-2: #0A2E23;
    --gold: #C9A35C;
    --gold-soft: #E3CB94;
    --card: #FAF6EE;
    --ink: #1A2620;
    --muted: #5C6B63;
    --line: #E2D9C4;
  }

  *{ box-sizing: border-box; }

  html, body{ height:100%; }

  body{
    margin:0;
    min-height:100vh;
    font-family:'Inter', sans-serif;
    background:
      radial-gradient(circle at 20% 15%, rgba(201,163,92,0.10), transparent 40%),
      radial-gradient(circle at 80% 85%, rgba(201,163,92,0.08), transparent 45%),
      linear-gradient(160deg, var(--bg-deep) 0%, var(--bg-deep-2) 100%);
    position:relative;
    overflow:hidden;
  }

  /* subtle geometric pattern overlay, faint */
  body::before{
    content:"";
    position:absolute;
    inset:0;
    background-image:
      repeating-linear-gradient(45deg, rgba(201,163,92,0.035) 0px, rgba(201,163,92,0.035) 1px, transparent 1px, transparent 26px),
      repeating-linear-gradient(-45deg, rgba(201,163,92,0.035) 0px, rgba(201,163,92,0.035) 1px, transparent 1px, transparent 26px);
    pointer-events:none;
  }

  .page{
    position:relative;
    z-index:1;
    min-height:100vh;
    display:flex;
    flex-direction:column;
  }

  .center-wrap{
    flex:1;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:32px 16px;
  }

  /* Container adjustments */
#step1 {
  max-width: 400px;         /* Reduces the width of the form */
  margin: 0 auto;           /* Centers the container itself on the page */
  display: flex;
  flex-direction: column;   /* Stacks all items vertically */
  align-items: center;      /* Centers all items by default */
  text-align: center;       /* Centers inline text inside elements */
}

/* Ensure full-width elements span properly while centered */
.field, .actions, #emailInput {
  width: 100%;
}

/* Specific overrides for left-alignment */
#step1 .create-link {
  align-self: flex-start;   /* Overrides center alignment to align left */
  text-align: left;
  width: 100%;
  margin-bottom: 15px;      /* Adjust spacing as needed */
}

#step1 .info-row {
  align-self: flex-start;   /* Overrides center alignment to align left */
  text-align: left;
             /* Keeps SVG and text inline */
  align-items: flex-start;
  gap: 10px;                /* Adds spacing between icon and text */
}


  .card{
    position: relative;
  z-index: 1;
  width: 100%;
  max-width: 640px;
  background: var(--card);
  border-radius: 22px;
  padding: 44px 36px 32px;
  box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset, 0 30px 60px -20px rgba(0,0,0,0.45);
  border: 1px solid rgba(201,163,92,0.25);
  height: 675px;
  display: flex;
  flex-direction: column;
  }

  .tasbih-icon{
    width:84px;
    height:84px;
    margin:0 auto 22px;
    display:block;
  }

  h1{
    font-family:'Amiri', serif;
    font-size:27px;
    line-height:1.3;
    color:var(--ink);
    text-align:center;
    margin:0 0 26px;
    font-weight:700;
  }

  .field{
    position:relative;
    margin-bottom:20px;
  }

  .field input{
    width:100%;
    padding:15px 18px;
    border-radius:14px;
    border:1.5px solid var(--line);
    background:#fff;
    font-size:15px;
    font-family:'Inter', sans-serif;
    color:var(--ink);
    outline:none;
    transition:border-color .15s ease, box-shadow .15s ease;
  }

  .field input:focus{
    border-color:var(--gold);
    box-shadow:0 0 0 3px rgba(201,163,92,0.18);
  }

  .field input::placeholder{ color:#9AA59E; }

  /* two-step: combined email+password box like Apple's flow */
  .credentials-box{
    border:1.5px solid var(--line);
    border-radius:14px;
    background:#fff;
    overflow:hidden;
    margin-bottom:20px;
  }
  .credentials-box .sub-field{
    position:relative;
    padding:8px 18px 10px;
  }
  .credentials-box .sub-field + .sub-field{
    border-top:1px solid var(--line);
  }
  .credentials-box label{
    display:block;
    font-size:11.5px;
    color:var(--muted);
    margin-bottom:2px;
  }
  .credentials-box input{
    width:100%;
    border:none;
    outline:none;
    padding:2px 0 4px;
    font-size:15px;
    font-family:'Inter', sans-serif;
    color:var(--ink);
    background:transparent;
  }
  .credentials-box.single-field .sub-field{ padding:15px 18px; }
  .credentials-box.single-field label{ display:none; }

  .keep-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    flex-wrap:wrap;
    gap:10px;
    margin-bottom:26px;
    font-size:13.5px;
  }
  .keep-row .checkbox-label{
    display:flex;
    align-items:center;
    gap:8px;
    color:var(--ink);
    cursor:pointer;
  }
  .keep-row input[type="checkbox"]{
    width:17px;
    height:17px;
    accent-color:#1E6B4F;
    cursor:pointer;
  }
  .keep-row a{
    color:#1E5C44;
    text-decoration:none;
    font-weight:600;
  }
  .keep-row a:hover{ text-decoration:underline; }

  .btn-signin{
    display:block;
    width:100%;
    padding:15px 16px;
    border:none;
    border-radius:13px;
    background:linear-gradient(180deg, #1E6B4F, #14523C);
    color:#fff;
    font-size:15px;
    font-weight:600;
    font-family:'Inter', sans-serif;
    cursor:pointer;
    transition:filter .12s ease, transform .12s ease;
  }
  .btn-signin:hover{ filter:brightness(1.08); }
  .btn-signin:active{ transform:scale(0.99); }

  .step{ display:none; }
  .step.active{
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  #step2.step.active{
    justify-content: center;
  }

  .create-link{
    display:block;
    font-size:14px;
    color:#1E5C44;
    text-decoration:none;
    font-weight:600;
    margin-bottom:18px;
  }
  .create-link:hover{ text-decoration:underline; }

  .info-row{
   
    gap:12px;
    margin-bottom:26px;
  }

  .info-row svg{ flex:0 0 auto; margin-top:2px; }

  .info-row p{
    margin:0;
    font-size:12.5px;
    line-height:1.55;
    color:var(--muted);
  }

  .info-row a{ color:#1E5C44; text-decoration:none; font-weight:600; }
  .info-row a:hover{ text-decoration:underline; }

  .actions{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }

  @media (max-width: 380px){
    .actions{ flex-direction:column; }
    .btn{ flex:1 1 100%; min-width:0; }
  }

  .btn{
    flex:1;
    min-width:140px;
    padding:14px 16px;
    border-radius:13px;
    border:none;
    font-size:14.5px;
    font-weight:600;
    font-family:'Inter', sans-serif;
    cursor:pointer;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:8px;
    white-space:nowrap;
    transition:transform .12s ease, filter .12s ease;
  }

  .btn-secondary{ flex:1.35; }

  @media (max-width: 600px){
    .center-wrap{ padding:28px 24px; align-items:flex-start; }
    .card{
      max-width:100%;
      width:100%;
      height:auto;
      padding:0;
      background:transparent;
      border:none;
      border-radius:0;
      box-shadow:none;
    }
    .tasbih-icon{ width:96px; height:96px; }
  }

  .btn:active{ transform:scale(0.98); }

  .btn-primary{
    background:linear-gradient(180deg, #1E6B4F, #14523C);
    color:#fff;
  }
  .btn-primary:hover{ filter:brightness(1.08); }

  .btn-secondary{
    background:var(--ink);
    color:var(--gold-soft);
  }
  .btn-secondary:hover{ filter:brightness(1.15); }

  .passkey-note{
    text-align:center;
    font-size:11.5px;
    color:var(--muted);
    margin-left: 184px;
  }

  .footer{
    text-align:center;
    padding:20px 16px 24px;
    font-size:11px;
    color:rgba(255,255,255,0.65);
  }
  .footer a{ color:rgba(255,255,255,0.78); text-decoration:none; margin:0 8px; }
  .footer a:hover{ text-decoration:underline; }
  .footer .copyright{ margin-top:8px; display:block; color:rgba(255,255,255,0.45); }
</style>
</head>
<body>

  <div class="page">
    <div class="center-wrap">
      <div class="card">
        <svg class="tasbih-icon" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="50" cy="50" r="34" stroke="#C9A35C" stroke-width="1.4" stroke-dasharray="2 6"/>
          <g fill="#1E6B4F">
            <circle cx="50" cy="16" r="5.2"/>
            <circle cx="68" cy="21" r="5.2"/>
            <circle cx="80" cy="35" r="5.2"/>
            <circle cx="84" cy="50" r="5.2"/>
            <circle cx="80" cy="65" r="5.2"/>
            <circle cx="68" cy="79" r="5.2"/>
            <circle cx="50" cy="84" r="5.2"/>
            <circle cx="32" cy="79" r="5.2"/>
            <circle cx="20" cy="65" r="5.2"/>
            <circle cx="16" cy="50" r="5.2"/>
            <circle cx="20" cy="35" r="5.2"/>
            <circle cx="32" cy="21" r="5.2"/>
          </g>
          <circle cx="50" cy="50" r="9" fill="#C9A35C"/>
        </svg>

        <h1>Sign in with<br>Tasbih Account</h1>

        <!-- STEP 1: email entry -->
        <div class="step active" id="step1">
          <div class="field">
            <input type="email" id="emailInput" placeholder="Email or Phone Number" autocomplete="email">
          </div>

          <a href="#" class="create-link">Create Your Tasbih Account</a>

          <div class="info-row">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <circle cx="9" cy="7" r="3" fill="#1E6B4F"/>
              <path d="M3 19c0-3.3 2.7-6 6-6s6 2.7 6 6" fill="#1E6B4F"/>
              <circle cx="17" cy="8" r="2.4" fill="#9DB6A6"/>
              <path d="M13 19c0-2.6 1.8-4.7 4-5" stroke="#9DB6A6" stroke-width="1.6" fill="none" stroke-linecap="round"/>
            </svg>
            <p>
              Your Tasbih Account is used to sync your dhikr counts and access your data securely.
              We keep a record of certain activity for support and reporting purposes.
              <a href="#">See how your data is managed…</a>
            </p>
          </div>

          <div class="actions">
            <button class="btn btn-primary" id="continueBtn">Continue</button>
            <button class="btn btn-secondary">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"><path d="M12 12c2.2 0 4-1.8 4-4s-1.8-4-4-4-4 1.8-4 4 1.8 4 4 4zm0 2c-3.3 0-8 1.7-8 5v2h16v-2c0-3.3-4.7-5-8-5z" fill="#E3CB94"/></svg>
              Sign in with Passkey
            </button>
          </div>
          <p class="passkey-note">Requires a device with iOS 17 or later.</p>
        </div>

        <!-- STEP 2: password entry -->
        <div class="step" id="step2">
          <div class="credentials-box">
            <div class="sub-field">
              <label>Email</label>
              <input type="email" id="emailDisplay" readonly>
            </div>
            <div class="sub-field">
              <label>Password</label>
              <input type="password" id="passwordInput" placeholder="Password" autocomplete="current-password">
            </div>
          </div>

          <div class="keep-row">
            <label class="checkbox-label">
              <input type="checkbox" id="keepSignedIn">
              Keep me signed in
            </label>
            <a href="#">Forgotten password?</a>
          </div>

          <button class="btn-signin" id="signInBtn">Sign In</button>
        </div>
      </div>
    </div>

    <div class="footer">
      <a href="#">System Status</a>
      <a href="#">Privacy Policy</a>
      <a href="#">Terms &amp; Conditions</a>
      <span class="copyright">Copyright © 2026 Tasbih Inc. All rights reserved.</span>
    </div>
  </div>

  <script>
    const continueBtn = document.getElementById('continueBtn');
    const step1 = document.getElementById('step1');
    const step2 = document.getElementById('step2');
    const emailInput = document.getElementById('emailInput');
    const emailDisplay = document.getElementById('emailDisplay');
    const passwordInput = document.getElementById('passwordInput');
    const signInBtn = document.getElementById('signInBtn');

    continueBtn.addEventListener('click', () => {
      const emailVal = emailInput.value.trim();
      if (!emailVal) {
        emailInput.focus();
        return;
      }
      emailDisplay.value = emailVal;
      step1.classList.remove('active');
      step2.classList.add('active');
      setTimeout(() => passwordInput.focus(), 50);
    });

    emailInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') continueBtn.click();
    });

    signInBtn.addEventListener('click', () => {
      if (!passwordInput.value) {
        passwordInput.focus();
        return;
      }
      // Hook up real authentication here, then redirect to the OTP page.
      window.location.href = 'otp.html?email=' + encodeURIComponent(emailDisplay.value);
    });

    passwordInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') signInBtn.click();
    });
  </script>

</body>
</html>