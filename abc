async function openSurah(surahNumber) {
    const root = document.getElementById('quranRoot');
    window.quranState.currentSurah = surahNumber;

    if (window.quranState.surahCache[surahNumber]) {
        renderSurahReader(window.quranState.surahCache[surahNumber]);
        return;
    }

    root.innerHTML = `<div class="status-banner"><i class="fa-solid fa-circle-notch fa-spin"></i><span>Loading surah…</span></div>`;

    try {
        const url = `https://api.alquran.cloud/v1/surah/${surahNumber}/editions/quran-uthmani,en.sahih`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (data.code !== 200) throw new Error(data.status || 'API error');

        window.quranState.surahCache[surahNumber] = data.data;
        renderSurahReader(data.data);
    } catch (e) {
        console.error('Surah fetch failed:', e);
        root.innerHTML = `<div class="status-banner error"><i class="fa-solid fa-triangle-exclamation"></i><span>Couldn't load this surah right now (network issue). <button class="btn-inline" onclick="openSurah(${surahNumber})">Retry</button></span></div>`;
    }
}

function renderSurahReader(editions) {
    const root = document.getElementById('quranRoot');
    const arabicEd = editions.find(e => e.edition.identifier === 'quran-uthmani');
    const englishEd = editions.find(e => e.edition.identifier === 'en.sahih');
    if (!arabicEd) return;

    const ayahCount = arabicEd.ayahs.length;
    const versesHtml = arabicEd.ayahs.map((ayah, i) => {
        const englishText = englishEd ? englishEd.ayahs[i].text : '';
        return `
            <div style="border-bottom:1px solid var(--border-color); padding:1rem 0;">
                <div style="display:flex; gap:0.6rem; align-items:baseline; margin-bottom:0.5rem;">
                    <span style="
                        width:24px; height:24px; border-radius:50%; background:var(--bg-elevated); border:1px solid var(--emerald);
                        display:flex; align-items:center; justify-content:center; font-size:0.65rem; color:var(--emerald-bright); flex-shrink:0;
                    ">${ayah.numberInSurah}</span>
                </div>
                <div class="arabic" style="font-size:1.5rem; text-align:right; color:var(--text-main); line-height:2; margin-bottom:0.6rem;" dir="rtl">${escapeHtml(ayah.text)}</div>
                ${englishText ? `<div style="font-size:0.88rem; color:var(--text-muted); line-height:1.6;">${escapeHtml(englishText)}</div>` : ''}
            </div>
        `;
    }).join('');

    root.innerHTML = `
        <button class="btn-outline-sm" style="margin-bottom:1rem;" onclick="backToSurahList()"><i class="fa-solid fa-arrow-left"></i> Back to Surahs</button>
        <div class="panel" style="text-align:center; margin-bottom:1rem;">
            <div class="arabic" style="font-size:1.8rem; color:var(--gold-soft);">${escapeHtml(arabicEd.name)}</div>
            <div style="color:var(--text-muted); font-size:0.85rem; margin-top:0.3rem;">${escapeHtml(arabicEd.englishName)} — ${escapeHtml(arabicEd.englishNameTranslation)}</div>
            <div style="color:var(--text-dim); font-size:0.75rem; margin-top:0.3rem;">${arabicEd.revelationType} • ${ayahCount} Ayahs</div>
        </div>
        <div class="panel">${versesHtml}</div>
    `;
}

